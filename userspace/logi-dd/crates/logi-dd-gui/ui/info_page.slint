import { Button, ListView, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One cell of the Info page's button tester grid: the wheel button's
// evdev code (informational), its label from `evtest::WHEEL_BUTTONS`,
// and whether it is currently held. The Rust reader thread pushes the
// whole list at ~30 Hz while the page is open.
export struct TestButton {
    code: int,
    label: string,
    pressed: bool,
}

// One live axis bar (pedals + handbrake): a label and the raw 0..65535
// value.
export struct TestAxis {
    label: string,
    value: int,
}

// A small horizontal 0..65535 bar.
component AxisBar inherits Rectangle {
    in property <int> value: 0;
    height: 12px;
    border-radius: 6px;
    background: Palette.alternate-background;
    border-width: 1px;
    border-color: Theme.panel-border;

    Rectangle {
        x: 0;
        width: parent.width * min(max(root.value, 0), 65535) / 65535;
        height: parent.height;
        border-radius: 6px;
        background: Palette.accent-background;
    }
}

// The Info page: device identity (serial, firmware) on top, then the live
// input monitor (steering dial, pedal bars, light-up button grid, hat
// state), the two guarded force-feedback simulations, and the project
// documentation link at the bottom. The monitor auto-starts whenever this
// page is open and a wheel evdev node is found; everything live is pushed
// from the Rust reader thread, and the two sim buttons round-trip through
// a confirm dialog before their callbacks ever fire (the wheel physically
// moves).
export component InfoPage inherits Rectangle {
    // Device identity, read through the driver's sysfs attrs (the registry
    // Info rows); empty strings while no wheel is bound.
    in property <string> serial: "";
    in property <string> firmware: "";
    // Project home, opened via `open-url` (xdg-open on the Rust side).
    in property <string> project-url: "";
    callback open-url(string);

    // Whether a wheel evdev node was found; gates the live monitor body
    // and both sim buttons. `scanned` keeps the empty state from
    // flashing "no wheel" before the first discovery finishes.
    in property <bool> available: false;
    in property <bool> scanned: false;
    in property <string> device-name: "";
    // Steering, pre-converted on the Rust side: the signed degrees for
    // the needle, the formatted readout text, and the configured range.
    in property <float> degrees: 0;
    in property <string> degrees-text: "0.0 deg";
    in property <int> range: 900;
    in property <[TestButton]> buttons: [];
    in property <string> hat: "centered";
    in property <[TestAxis]> axes: [];
    // True while a simulation plays; disables both sim buttons.
    in property <bool> sim-running: false;
    in property <string> sim-error: "";

    callback rescan();
    // Fired only from the confirm dialog's Continue button, never
    // directly from the sim buttons.
    callback sim-constant();
    callback sim-texture();

    // The confirm dialog's state: 0 closed, 1 constant force, 2 texture.
    private property <int> confirm-kind: 0;

    background: transparent;

    VerticalLayout {
        spacing: Theme.gutter;

        // Device identity + the input-device rescan affordance.
        Rectangle {
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            HorizontalLayout {
                padding: 14px;
                spacing: Theme.gutter;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            width: 90px;
                            text: "Serial";
                            font-weight: 600;
                            color: Theme.muted-text-color;
                        }
                        Text {
                            horizontal-stretch: 1;
                            text: root.serial == "" ? "-" : root.serial;
                            color: Theme.text-color;
                            overflow: elide;
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            width: 90px;
                            text: "Firmware";
                            font-weight: 600;
                            color: Theme.muted-text-color;
                        }
                        Text {
                            horizontal-stretch: 1;
                            text: root.firmware == "" ? "-" : root.firmware;
                            color: Theme.text-color;
                            wrap: word-wrap;
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Button {
                        text: "Rescan";
                        clicked => { root.rescan(); }
                    }
                }
            }
        }

        if !root.available: VerticalLayout {
            vertical-stretch: 1;
            alignment: center;
            spacing: 10px;

            Text {
                text: root.scanned ? "No wheel input found" : "Looking for the wheel...";
                font-size: 17px;
                font-weight: 700;
                horizontal-alignment: center;
                color: Theme.text-color;
            }
            Text {
                text: root.scanned
                    ? "Connect the wheel to this machine, then press Rescan above.\nThe monitor reads the wheel's /dev/input event device, so your user needs read access to it (the project's udev rule sets this up)."
                    : "Scanning /dev/input for the wheel...";
                horizontal-alignment: center;
                color: Theme.muted-text-color;
                wrap: word-wrap;
            }
            if root.sim-error != "": Text {
                // Discovery found a node but it could not be opened
                // (permissions, ...): surface the reason here too.
                text: root.sim-error;
                horizontal-alignment: center;
                color: Theme.error-color;
                wrap: word-wrap;
            }
        }

        if root.available: HorizontalLayout {
            vertical-stretch: 1;
            spacing: Theme.gutter;

            // Left column: rotation dial, pedals, simulations. Wrapped in
            // a Flickable so the sim section stays reachable in a short
            // window (the column is taller than the default window).
            Flickable {
                horizontal-stretch: 1;
                viewport-height: left-column.preferred-height;

                left-column := VerticalLayout {
                spacing: Theme.gutter;

                // Section: steering rotation.
                Rectangle {
                    background: Theme.panel-background;
                    border-radius: Theme.panel-radius;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;

                        Text {
                            text: "Steering";
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-color;
                        }
                        Text {
                            text: root.device-name;
                            font-size: 11px;
                            color: Theme.muted-text-color;
                            overflow: elide;
                        }
                        HorizontalLayout {
                            alignment: center;
                            dial := Rectangle {
                                width: 160px;
                                height: 160px;
                                border-radius: self.width / 2;
                                border-width: 3px;
                                border-color: Theme.panel-border;
                                background: Palette.alternate-background;

                                // Center hub.
                                Rectangle {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 7px;
                                    background: Theme.muted-text-color;
                                }
                                // Needle: a stroked line from the hub toward
                                // the rim, swung around the dial center by
                                // the live steering angle (0 deg = straight
                                // up, positive = clockwise/right).
                                needle := Path {
                                    width: 100%;
                                    height: 100%;
                                    viewbox-width: 160;
                                    viewbox-height: 160;
                                    stroke: Palette.accent-background;
                                    stroke-width: 5px;

                                    MoveTo { x: 80; y: 80; }
                                    LineTo {
                                        x: 80 + 62 * sin(root.degrees * 1deg);
                                        y: 80 - 62 * cos(root.degrees * 1deg);
                                    }
                                }
                            }
                        }
                        Text {
                            text: root.degrees-text;
                            font-size: 24px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            color: Theme.text-color;
                        }
                        Text {
                            text: "Range: \{root.range} deg (\{-root.range / 2} to +\{root.range / 2})";
                            font-size: 12px;
                            horizontal-alignment: center;
                            color: Theme.muted-text-color;
                        }
                    }
                }

                // Section: pedals + handbrake bars and the D-pad state.
                Rectangle {
                    background: Theme.panel-background;
                    border-radius: Theme.panel-radius;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;

                        Text {
                            text: "Pedals";
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-color;
                        }
                        for axis in root.axes: HorizontalLayout {
                            spacing: 8px;
                            Text {
                                width: 80px;
                                text: axis.label;
                                font-size: 12px;
                                vertical-alignment: center;
                                color: Theme.text-color;
                            }
                            AxisBar {
                                horizontal-stretch: 1;
                                value: axis.value;
                            }
                            Text {
                                width: 46px;
                                text: axis.value;
                                font-size: 11px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                color: Theme.muted-text-color;
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                width: 80px;
                                text: "D-pad";
                                font-size: 12px;
                                color: Theme.text-color;
                            }
                            Text {
                                text: root.hat;
                                font-size: 12px;
                                font-weight: 700;
                                color: Theme.text-color;
                            }
                        }
                    }
                }

                // Section: the two guarded force simulations.
                Rectangle {
                    vertical-stretch: 1;
                    background: Theme.panel-background;
                    border-radius: Theme.panel-radius;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        alignment: start;

                        Text {
                            text: "Force feedback test";
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-color;
                        }
                        Text {
                            text: "Plays a short, gentle effect (25% strength, 2 seconds) through the wheel's force-feedback path. The texture test plays a rumble-style texture through the FFB path.";
                            font-size: 12px;
                            color: Theme.muted-text-color;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                text: "Simulate force feedback";
                                enabled: root.available && !root.sim-running && root.confirm-kind == 0;
                                clicked => { root.confirm-kind = 1; }
                            }
                            Button {
                                text: "Simulate TrueForce texture";
                                enabled: root.available && !root.sim-running && root.confirm-kind == 0;
                                clicked => { root.confirm-kind = 2; }
                            }
                        }
                        if root.sim-running: Text {
                            text: "force playing...";
                            font-size: 12px;
                            font-weight: 700;
                            color: Theme.ok-color;
                        }
                        if root.sim-error != "": Text {
                            text: root.sim-error;
                            font-size: 12px;
                            color: Theme.error-color;
                            wrap: word-wrap;
                        }
                    }
                }
                }
            }

            // Right column: the layout image and the light-up button grid.
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.panel-background;
                border-radius: Theme.panel-radius;
                border-width: 1px;
                border-color: Theme.panel-border;

                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;

                    Text {
                        text: "Buttons";
                        font-size: 15px;
                        font-weight: 700;
                        color: Theme.text-color;
                    }
                    Image {
                        source: @image-url("assets/rs-wheel-hub-button-layout.png");
                        image-fit: contain;
                        vertical-stretch: 1;
                        min-height: 120px;
                    }
                    // Light-up rows, one per wheel button, scrollable so
                    // the image above keeps its share of the panel.
                    ListView {
                        vertical-stretch: 2;
                        for b in root.buttons: Rectangle {
                            height: 26px;

                            Rectangle {
                                width: parent.width - 8px;
                                height: 24px;
                                border-radius: 5px;
                                background: b.pressed ? Palette.accent-background : Palette.alternate-background;

                                Text {
                                    x: 8px;
                                    width: parent.width - 16px;
                                    height: 100%;
                                    text: b.label;
                                    font-size: 12px;
                                    font-weight: b.pressed ? 700 : 400;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    color: b.pressed ? Palette.accent-foreground : Theme.text-color;
                                }
                            }
                        }
                    }
                }
            }
        }

        // Documentation / source link, same styling as the link the Setup
        // page carries.
        HorizontalLayout {
            alignment: start;
            spacing: 6px;

            Text {
                text: "Documentation and source:";
                vertical-alignment: center;
                color: Theme.muted-text-color;
            }
            link := Text {
                text: root.project-url;
                vertical-alignment: center;
                color: Palette.accent-background;
                font-weight: 600;
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.open-url(root.project-url); }
                }
            }
        }
    }

    // Confirm dialog, painted over the whole page. No simulation ever
    // fires without pressing Continue here.
    if root.confirm-kind != 0: Rectangle {
        background: Theme.scrim;

        // Swallow clicks outside the dialog panel.
        TouchArea { }

        Rectangle {
            width: min(parent.width - 40px, 420px);
            height: panel-layout.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            panel-layout := VerticalLayout {
                padding: 18px;
                spacing: 12px;

                Text {
                    text: root.confirm-kind == 1 ? "Simulate force feedback" : "Simulate TrueForce texture";
                    font-size: 15px;
                    font-weight: 700;
                    color: Theme.text-color;
                }
                Text {
                    text: "The wheel WILL move. Keep hands and objects clear of the rim. Continue?";
                    font-size: 13px;
                    color: Theme.text-color;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Button {
                        text: "Cancel";
                        clicked => { root.confirm-kind = 0; }
                    }
                    Button {
                        text: "Continue";
                        primary: true;
                        clicked => {
                            if (root.confirm-kind == 1) {
                                root.sim-constant();
                            } else {
                                root.sim-texture();
                            }
                            root.confirm-kind = 0;
                        }
                    }
                }
            }
        }
    }
}
