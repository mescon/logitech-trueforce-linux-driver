import { Button, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One cell of the Info page's button tester grid: the wheel button's
// evdev code (informational), its label from `evtest::WHEEL_BUTTONS`,
// and whether it is currently held. The Rust reader thread pushes the
// whole list at ~30 Hz while the page is open.
export struct TestButton {
    code: int,
    label: string,
    pressed: bool,
}

// One live axis bar (pedals + handbrake): a label and the raw 0..65535
// value.
export struct TestAxis {
    label: string,
    value: int,
}

// One callout box on the wheel-layout image (`evtest::CALLOUT_BOXES`):
// center and size as fractions of the image dimensions, plus whether its
// button is currently held. Drawn as a green tint over the numbered white
// box, inside the rotated image element so it turns with the artwork.
export struct TestCallout {
    cx: float,
    cy: float,
    w: float,
    h: float,
    pressed: bool,
}

// A small horizontal 0..65535 bar.
component AxisBar inherits Rectangle {
    in property <int> value: 0;
    height: 12px;
    border-radius: 6px;
    background: Palette.alternate-background;
    border-width: 1px;
    border-color: Theme.panel-border;

    Rectangle {
        x: 0;
        width: parent.width * min(max(root.value, 0), 65535) / 65535;
        height: parent.height;
        border-radius: 6px;
        background: Palette.accent-background;
    }
}

// The Info page: device identity (serial, firmware) on top, then the live
// input monitor (the wheel image turning with the live steering angle,
// per-button callout highlights, the full button list beside the image,
// pedal bars, hat state), the two guarded force-feedback simulations, and
// the project documentation link at the bottom. The monitor auto-starts
// whenever this page is open and a wheel evdev node is found; everything
// live is pushed from the Rust reader thread, and the two sim buttons
// round-trip through a confirm dialog before their callbacks ever fire
// (the wheel physically moves).
export component InfoPage inherits Rectangle {
    // Device identity, read through the driver's sysfs attrs (the registry
    // Info rows); empty strings while no wheel is bound.
    in property <string> serial: "";
    in property <string> firmware: "";
    // Project home, opened via `open-url` (xdg-open on the Rust side).
    in property <string> project-url: "";
    callback open-url(string);

    // Whether a wheel evdev node was found; gates the live monitor body
    // and both sim buttons. `scanned` keeps the empty state from
    // flashing "no wheel" before the first discovery finishes.
    in property <bool> available: false;
    in property <bool> scanned: false;
    in property <string> device-name: "";
    // Steering, pre-converted on the Rust side: the signed degrees for
    // the needle, the formatted readout text, and the configured range.
    in property <float> degrees: 0;
    in property <string> degrees-text: "0.0 deg";
    in property <int> range: 900;
    in property <[TestButton]> buttons: [];
    in property <string> hat: "centered";
    in property <[TestAxis]> axes: [];
    // The layout image's callout boxes, tinted while pressed; see
    // `TestCallout`.
    in property <[TestCallout]> callouts: [];
    // True while a simulation plays; disables both sim buttons and shows
    // the Stop button.
    in property <bool> sim-running: false;
    in property <string> sim-error: "";

    callback rescan();
    // Fired only from the confirm dialog's Continue button, never
    // directly from the sim buttons.
    callback sim-constant();
    callback sim-texture();
    // Stops (and erases) the currently playing simulation immediately.
    callback sim-stop();

    // The confirm dialog's state: 0 closed, 1 constant force, 2 texture.
    private property <int> confirm-kind: 0;

    background: transparent;

    VerticalLayout {
        spacing: Theme.gutter;

        // Device identity + the input-device rescan affordance.
        Rectangle {
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            HorizontalLayout {
                padding: 14px;
                spacing: Theme.gutter;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            width: 90px;
                            text: "Serial";
                            font-weight: 600;
                            color: Theme.muted-text-color;
                        }
                        Text {
                            horizontal-stretch: 1;
                            text: root.serial == "" ? "-" : root.serial;
                            color: Theme.text-color;
                            overflow: elide;
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            width: 90px;
                            text: "Firmware";
                            font-weight: 600;
                            color: Theme.muted-text-color;
                        }
                        Text {
                            horizontal-stretch: 1;
                            text: root.firmware == "" ? "-" : root.firmware;
                            color: Theme.text-color;
                            wrap: word-wrap;
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Button {
                        text: "Rescan";
                        clicked => { root.rescan(); }
                    }
                }
            }
        }

        if !root.available: VerticalLayout {
            vertical-stretch: 1;
            alignment: center;
            spacing: 10px;

            Text {
                text: root.scanned ? "No wheel input found" : "Looking for the wheel...";
                font-size: 17px;
                font-weight: 700;
                horizontal-alignment: center;
                color: Theme.text-color;
            }
            Text {
                text: root.scanned
                    ? "Connect the wheel to this machine, then press Rescan above.\nThe monitor reads the wheel's /dev/input event device, so your user needs read access to it (the project's udev rule sets this up)."
                    : "Scanning /dev/input for the wheel...";
                horizontal-alignment: center;
                color: Theme.muted-text-color;
                wrap: word-wrap;
            }
            if root.sim-error != "": Text {
                // Discovery found a node but it could not be opened
                // (permissions, ...): surface the reason here too.
                text: root.sim-error;
                horizontal-alignment: center;
                color: Theme.error-color;
                wrap: word-wrap;
            }
        }

        // The live monitor. One panel holds the wheel image (turning with
        // the live steering angle, callout tints riding on it) with the
        // full button list BESIDE it, wrapped into columns so every
        // button is visible at once; pedals and the sims stack below.
        // The Flickable is only the fallback for very short windows: at
        // the default window size everything fits without scrolling.
        if root.available: Flickable {
            vertical-stretch: 1;
            viewport-height: max(monitor-column.preferred-height, self.height);

            monitor-column := VerticalLayout {
                spacing: Theme.gutter;

                // Section: steering + buttons, side by side.
                Rectangle {
                    vertical-stretch: 1;
                    background: Theme.panel-background;
                    border-radius: Theme.panel-radius;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    HorizontalLayout {
                        padding: 14px;
                        spacing: Theme.gutter;

                        // Left half: the layout image, rotated by the live
                        // steering angle, with the degrees readout under it.
                        VerticalLayout {
                            horizontal-stretch: 11;
                            spacing: 4px;

                            Text {
                                // The box tests everything (steering, pedals,
                                // buttons, haptics), not just the wheel axis.
                                text: "Test area";
                                font-size: 15px;
                                font-weight: 700;
                                color: Theme.text-color;
                            }
                            Text {
                                text: root.device-name;
                                font-size: 11px;
                                color: Theme.muted-text-color;
                                overflow: elide;
                            }
                            img-area := Rectangle {
                                vertical-stretch: 1;
                                min-height: 230px;
                                // Manual `contain` fit: the rotated element
                                // must match the drawn image exactly, so the
                                // callout children can position themselves
                                // as fractions of ITS size (= fractions of
                                // the source image).
                                property <float> aspect: 2500 / 2160;
                                property <length> img-w: min(self.width, self.height * self.aspect);

                                // Turned by the live steering angle
                                // (positive degrees = turned right =
                                // clockwise on screen). `transform-rotation`
                                // is the reserved rotation property every
                                // Slint element carries (`rotation-angle`
                                // only exists on Image/Text); it rotates the
                                // element AND its children around
                                // `transform-origin`, which defaults to the
                                // element's center.
                                rotator := Rectangle {
                                    width: img-area.img-w;
                                    height: self.width / img-area.aspect;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    transform-rotation: root.degrees * 1deg;

                                    Image {
                                        width: 100%;
                                        height: 100%;
                                        source: @image-url("assets/rs-wheel-hub-button-layout.png");
                                        image-fit: contain;
                                    }
                                    // Pressed-button tints over the numbered
                                    // callout boxes; children of `rotator`,
                                    // so they turn with the artwork. Semi-
                                    // transparent green keeps the number
                                    // readable underneath.
                                    for c in root.callouts: Rectangle {
                                        x: (c.cx - c.w / 2) * rotator.width;
                                        y: (c.cy - c.h / 2) * rotator.height;
                                        width: c.w * rotator.width;
                                        height: c.h * rotator.height;
                                        border-radius: 4px;
                                        background: #00c8538c;
                                        visible: c.pressed;
                                    }
                                }
                            }
                            Text {
                                text: root.degrees-text;
                                font-size: 20px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                color: Theme.text-color;
                            }
                            Text {
                                text: "Range: \{root.range} deg (\{-root.range / 2} to +\{root.range / 2})";
                                font-size: 12px;
                                horizontal-alignment: center;
                                color: Theme.muted-text-color;
                            }
                        }

                        // Right half: every wheel button as a light-up
                        // chip, wrapped into 2-3 columns (never a scroll
                        // list: the whole set stays visible), with the
                        // D-pad state underneath.
                        VerticalLayout {
                            horizontal-stretch: 9;
                            spacing: 8px;
                            alignment: start;

                            Text {
                                text: "Buttons";
                                font-size: 15px;
                                font-weight: 700;
                                color: Theme.text-color;
                            }
                            grid := Rectangle {
                                property <int> columns: self.width > 440px ? 3 : 2;
                                property <int> rows: ceil(root.buttons.length / self.columns);
                                property <length> cell-w: (self.width - (self.columns - 1) * 6px) / self.columns;
                                height: self.rows * 26px;

                                // Column-major: reads top to bottom, then
                                // wraps to the next column.
                                for b[i] in root.buttons: Rectangle {
                                    x: floor(i / grid.rows) * (grid.cell-w + 6px);
                                    y: mod(i, grid.rows) * 26px;
                                    width: grid.cell-w;
                                    height: 24px;
                                    border-radius: 5px;
                                    background: b.pressed ? Palette.accent-background : Palette.alternate-background;

                                    Text {
                                        x: 8px;
                                        width: parent.width - 16px;
                                        height: 100%;
                                        text: b.label;
                                        font-size: 12px;
                                        font-weight: b.pressed ? 700 : 400;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        color: b.pressed ? Palette.accent-foreground : Theme.text-color;
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    width: 80px;
                                    text: "D-pad";
                                    font-size: 12px;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: root.hat;
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                            }
                        }
                    }
                }

                // Section: pedals + handbrake bars.
                Rectangle {
                    background: Theme.panel-background;
                    border-radius: Theme.panel-radius;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;

                        Text {
                            text: "Pedals";
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-color;
                        }
                        for axis in root.axes: HorizontalLayout {
                            spacing: 8px;
                            Text {
                                width: 80px;
                                text: axis.label;
                                font-size: 12px;
                                vertical-alignment: center;
                                color: Theme.text-color;
                            }
                            AxisBar {
                                horizontal-stretch: 1;
                                value: axis.value;
                            }
                            Text {
                                width: 46px;
                                text: axis.value;
                                font-size: 11px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                color: Theme.muted-text-color;
                            }
                        }
                    }
                }

                // Section: the two guarded force simulations.
                Rectangle {
                    background: Theme.panel-background;
                    border-radius: Theme.panel-radius;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        alignment: start;

                        Text {
                            text: "Force feedback test";
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-color;
                        }
                        Text {
                            text: "Plays a short, gentle effect (25% strength, 2 seconds) through the wheel's force-feedback path. The texture test plays a rumble-style texture through the FFB path.";
                            font-size: 12px;
                            color: Theme.muted-text-color;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                text: "Simulate force feedback";
                                enabled: root.available && !root.sim-running && root.confirm-kind == 0;
                                clicked => { root.confirm-kind = 1; }
                            }
                            Button {
                                text: "Simulate TrueForce texture";
                                enabled: root.available && !root.sim-running && root.confirm-kind == 0;
                                clicked => { root.confirm-kind = 2; }
                            }
                        }
                        // While an effect plays: the status plus a Stop
                        // button that stops and erases it immediately.
                        if root.sim-running: HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            Text {
                                text: "force playing...";
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                color: Theme.ok-color;
                            }
                            Button {
                                text: "Stop";
                                clicked => { root.sim-stop(); }
                            }
                        }
                        if root.sim-error != "": Text {
                            text: root.sim-error;
                            font-size: 12px;
                            color: Theme.error-color;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }

        // Documentation / source link, same styling as the link the Setup
        // page carries.
        HorizontalLayout {
            alignment: start;
            spacing: 6px;

            Text {
                text: "Documentation and source:";
                vertical-alignment: center;
                color: Theme.muted-text-color;
            }
            link := Text {
                text: root.project-url;
                vertical-alignment: center;
                color: Palette.accent-background;
                font-weight: 600;
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.open-url(root.project-url); }
                }
            }
        }
    }

    // Confirm dialog, painted over the whole page. No simulation ever
    // fires without pressing Continue here.
    if root.confirm-kind != 0: Rectangle {
        background: Theme.scrim;

        // Swallow clicks outside the dialog panel.
        TouchArea { }

        Rectangle {
            width: min(parent.width - 40px, 420px);
            height: panel-layout.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            panel-layout := VerticalLayout {
                padding: 18px;
                spacing: 12px;

                Text {
                    text: root.confirm-kind == 1 ? "Simulate force feedback" : "Simulate TrueForce texture";
                    font-size: 15px;
                    font-weight: 700;
                    color: Theme.text-color;
                }
                Text {
                    text: "The wheel WILL move. Keep hands and objects clear of the rim. Continue?";
                    font-size: 13px;
                    color: Theme.text-color;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Button {
                        text: "Cancel";
                        clicked => { root.confirm-kind = 0; }
                    }
                    Button {
                        text: "Continue";
                        primary: true;
                        clicked => {
                            if (root.confirm-kind == 1) {
                                root.sim-constant();
                            } else {
                                root.sim-texture();
                            }
                            root.confirm-kind = 0;
                        }
                    }
                }
            }
        }
    }
}
