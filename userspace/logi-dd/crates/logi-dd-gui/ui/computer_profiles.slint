import { Button, LineEdit, ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";

// The desktop-mode half of the Profiles page: the computer-side profile
// store (one file per profile under ~/.config/logi-dd/profiles, managed
// by the Rust worker). Shown below the settings list (which then carries
// only the Mode row) while the wheel is in desktop mode; in onboard mode
// the wheel's own slot picker takes over instead. All I/O runs on the
// worker thread; this component only renders the pushed list and status.
export component ComputerProfiles inherits Rectangle {
    // The saved profile names, sorted; pushed after every list-changing
    // request and on every Profiles page load.
    in property <[string]> profiles: [];
    // The last save/apply/delete outcome, "" for none; `status-error`
    // picks the error color over the ok color.
    in property <string> status: "";
    in property <bool> status-error: false;

    callback apply-profile(string);
    callback delete-profile(string);
    callback save-profile(string);

    background: Theme.panel-background;
    border-radius: Theme.panel-radius;
    border-width: 1px;
    border-color: Theme.panel-border;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "Computer profiles";
            font-size: 15px;
            font-weight: 700;
            color: Theme.text-color;
        }
        Text {
            text: "Snapshots of every wheel setting, stored on this computer. Apply replays a snapshot onto the wheel; the wheel's own onboard slots are managed in onboard mode instead.";
            font-size: 12px;
            color: Theme.muted-text-color;
            wrap: word-wrap;
        }

        if root.profiles.length == 0: Text {
            text: "No saved profiles yet. Set the wheel up the way you like it, then save it under a name below.";
            color: Theme.faint-text-color;
            wrap: word-wrap;
        }

        ListView {
            vertical-stretch: 1;

            for name in root.profiles: Rectangle {
                height: 52px;

                // Each profile is its own card (mockup's card list).
                Rectangle {
                    y: 4px;
                    height: parent.height - 8px;
                    background: Theme.control-background;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.panel-border;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        Text {
                            horizontal-stretch: 1;
                            text: name;
                            vertical-alignment: center;
                            font-weight: 600;
                            color: Theme.text-color;
                            overflow: elide;
                        }
                        VerticalLayout {
                            alignment: center;
                            Button {
                                text: "Apply";
                                clicked => { root.apply-profile(name); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Button {
                                text: "Delete";
                                clicked => { root.delete-profile(name); }
                            }
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;

            name-edit := LineEdit {
                horizontal-stretch: 1;
                placeholder-text: "Profile name (1-32 characters)";
            }
            Button {
                text: "Save current as...";
                primary: true;
                clicked => { root.save-profile(name-edit.text); }
            }
        }

        if root.status != "": Text {
            text: root.status;
            font-size: 12px;
            color: root.status-error ? Theme.error-color : Theme.ok-color;
            wrap: word-wrap;
        }
    }
}
