import { Button, LineEdit, TextEdit, ListView, ScrollView, Slider, SpinBox, Switch, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One row of the Setup page's Proton games list, built on the Rust side
// from `logi_dd_core::steam::installed_games`: the game's display name,
// the wine prefix path the installer targets, and whether the shim's
// marker DLL is present in it.
export struct SetupGame {
    name: string,
    prefix: string,
    installed: bool,
}

// One row of the compatibility table, built on the Rust side
// (`bridge::compat_rows`): the game, how force feedback reaches it, whether
// it carries native TrueForce, the "Simulated TF" cell, and a one-line
// plain-English "what to do". Titles the tf-sim daemon can identify from
// their telemetry carry their tf-sim game id in `sim-id` and render a
// live per-game toggle + intensity (from tf-sim.conf, `sim-enabled` /
// `sim-intensity`); every other row keeps the static `tf` text ("possible
// (needs a parser)" for FFB-only titles, "n/a (native)" where the shim
// already delivers real TrueForce, "no" where there is no telemetry).
export struct SetupCompatRow {
    game: string,
    how: string,
    native-tf: string,
    tf: string,
    setup: string,
    sim-id: string,
    sim-enabled: bool,
    sim-intensity: int,
}

// The sidebar's "Setup" page: the DirectInput FFB proxy (logi-ffb), the
// TrueForce SDK folder + per-game shim management, and a documentation
// link, shown instead of the settings list whenever `App.selected-category`
// equals `App.setup-index` (see `app.slint`'s content area). Nothing here
// is a device setting, so nothing goes through `Category`/`SettingRow`; the
// Rust side (`main.rs`) wires the callbacks directly to `std::process`
// calls, off the UI thread for the shim installer and the Steam scan.
export component Setup inherits Rectangle {
    in property <string> project-url: "";
    in property <bool> ffb-found: false;
    // The resolved helper paths ("" while not found): a PATH hit, or the
    // repo-checkout fallback (logi-ffb next to the app binary, the
    // installer in tools/ above it).
    in property <string> ffb-path: "";
    in property <bool> shim-found: false;
    in property <string> shim-path: "";
    in property <bool> shim-running: false;
    in property <string> shim-output: "";
    // The SDK folder field's initial text ($LOGITECH_TRUEFORCE_SDK_DIR,
    // else the XDG default) plus the resolution outcome: `sdk-status` is
    // the concrete answer ("SDK DLLs: found at <path>" or a not-found
    // line) the Rust side recomputes on page load and on every
    // edit-accept, resolving in the installer's own order (field, env
    // var, repo sdk/, XDG default); `sdk-valid` colors it green/red.
    in property <string> sdk-dir: "";
    in property <bool> sdk-valid: false;
    in property <string> sdk-status: "";
    // The installed Proton games, scanned off the UI thread at startup and
    // after every install/remove/rescan; `games-scanned` gates the empty
    // state so "no Steam found" never flashes before the first scan lands.
    in property <[SetupGame]> games: [];
    in property <bool> games-scanned: false;
    // The compatibility table's rows, built on the Rust side so the
    // "Simulated TF" cells can carry live tf-sim.conf state; refreshed
    // after every per-game edit.
    in property <[SetupCompatRow]> compat-rows: [];
    // Simulated TrueForce (the logi-tf-sim daemon): the resolved binary
    // ("" while not found), whether the daemon is running, the master
    // switch/intensity/pitch from tf-sim.conf, and the test sweep's
    // run state + surfaced output.
    in property <bool> tf-found: false;
    in property <string> tf-path: "";
    in property <bool> tf-running: false;
    in property <bool> tf-enabled: false;
    in property <int> tf-intensity: 60;
    in property <int> tf-pitch: 100;
    in property <bool> tf-sweep-running: false;
    in property <string> tf-output: "";
    // The test sweep's consent dialog; the sweep only ever fires from its
    // Continue button, same discipline as the Test page's simulations.
    private property <bool> tf-confirm-open: false;

    // Copies "logi-ffb %command%" to the clipboard (best-effort, wl-copy
    // then xclip; the field next to the button is selectable as a fallback).
    callback copy-launch();
    // The SDK folder field's edit-accept: re-runs the full resolution and
    // pushes the fresh outcome back into `sdk-status`/`sdk-valid`.
    // Installs pass the RESOLVED directory explicitly (--sdk-dir), so what
    // the status line reports is exactly what an install uses.
    callback sdk-dir-edited(string);
    // Per-game shim runs, off the UI thread; the argument is the row's
    // wine prefix path. `shim-output` and `shim-running` are pushed back
    // once the run finishes, followed by a rescan.
    callback install-game(string);
    callback remove-game(string);
    callback rescan-games();
    // Opens `project-url` in the user's browser; wired to the same
    // `open-url` callback the Info category's link uses.
    callback open-url(string);
    // Simulated TrueForce edits, all writing tf-sim.conf on the Rust
    // side (one key per call, so hand-added lines survive).
    callback tf-set-enabled(bool);
    callback tf-set-intensity(int);
    callback tf-set-pitch(int);
    callback tf-start-daemon();
    callback tf-stop-daemon();
    // Fired only from the consent dialog's Continue button: runs
    // `logi-tf-sim --sweep` (about 6 s of real haptics) off the UI thread.
    callback tf-sweep();
    // SIGTERMs the running sweep so it stops cleanly (stop packets sent).
    callback tf-sweep-stop();
    // A compatibility row's live "Simulated TF" cell: the row's tf-sim
    // game id plus the new value.
    callback sim-game-enabled(string, bool);
    callback sim-game-intensity(string, int);

    background: transparent;

    VerticalLayout {
        spacing: Theme.gutter;

        Text {
            text: "Setup";
            font-size: 20px;
            font-weight: 700;
            color: Theme.text-color;
        }

        // The page content scrolls: at small window sizes (or with a long
        // games list) the columns are taller than the window, and without
        // a scroll surface the lower panels (e.g. Game compatibility) were
        // simply unreachable. Vertical-only: the viewport is pinned to the
        // visible width so the columns wrap instead of scrolling sideways.
        ScrollView {
            vertical-stretch: 1;
            viewport-width: self.visible-width;

            VerticalLayout {
                spacing: Theme.gutter;

                HorizontalLayout {
                    spacing: Theme.gutter;

                    // Left column: logi-ffb, the SDK folder + libtrueforce note,
                    // and the compatibility table.
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: Theme.gutter;

                        // Section: logi-ffb (DirectInput/Proton FFB proxy).
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Force feedback in games (logi-ffb)";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "DirectInput sims run through Proton (e.g. Le Mans Ultimate) do not get force feedback by default. Running the game through logi-ffb gives them FFB via a virtual wheel.";
                                    color: Theme.muted-text-color;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.ffb-found
                                        ? "logi-ffb: found: " + root.ffb-path
                                        : "logi-ffb: not found (PATH or next to this app)";
                                    font-size: 12px;
                                    color: root.ffb-found ? Theme.text-color : Theme.error-color;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "Add this to the game's Steam launch options:";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    LineEdit {
                                        horizontal-stretch: 1;
                                        text: "logi-ffb %command%";
                                        read-only: true;
                                    }
                                    Button {
                                        text: "Copy";
                                        clicked => { root.copy-launch(); }
                                    }
                                }
                            }
                        }

                        // Section: the TrueForce SDK folder + libtrueforce note.
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "TrueForce SDK folder";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                LineEdit {
                                    text: root.sdk-dir;
                                    placeholder-text: "Path to your Logitech SDK DLLs";
                                    accepted(text) => { root.sdk-dir-edited(text); }
                                }
                                // The concrete resolution outcome: green
                                // "found at <path>", or a red not-found
                                // line (the DLLs must be copied from a
                                // Windows G HUB install first).
                                Text {
                                    text: root.sdk-status;
                                    font-size: 12px;
                                    color: root.sdk-valid ? Theme.ok-color : Theme.error-color;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "Native Linux apps can also drive TrueForce through this project's libtrueforce library (userspace/libtrueforce). The SDK DLLs themselves come from Logitech's G HUB install on Windows and are never redistributed; the project README explains how to copy them here.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // Section: compatibility table (static reference).
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 4px;

                                Text {
                                    text: "Game compatibility";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "\"logi-ffb\" means launch with logi-ffb %command%. \"Native TF\" is the game's own built-in TrueForce. \"Simulated TF\" synthesizes TrueForce from the game's telemetry (see the Simulated TrueForce panel): titles the daemon can identify get a live per-game toggle + intensity here; \"possible (needs a parser)\" needs telemetry support added; \"n/a (native)\" already gets the real thing via the shim. Each game's recommended setup is the muted line under its name. * = expected to work, not verified on this driver yet.";
                                    font-size: 11px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                                // Column header for the per-game blocks
                                // below. The game name sits on its own full-
                                // width line inside each block (long titles
                                // would elide to nothing in this narrow left
                                // column), so the header only labels the
                                // three fixed-width columns beneath it. A
                                // trailing filler keeps them left-aligned.
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        width: 118px;
                                        text: "Force feedback";
                                        font-size: 11px;
                                        font-weight: 600;
                                        color: Theme.muted-text-color;
                                    }
                                    Text {
                                        width: 60px;
                                        text: "Native TF";
                                        font-size: 11px;
                                        font-weight: 600;
                                        color: Theme.muted-text-color;
                                    }
                                    Text {
                                        width: 175px;
                                        text: "Simulated TF";
                                        font-size: 11px;
                                        font-weight: 600;
                                        color: Theme.muted-text-color;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                }
                                // One block per title: the game name (its own
                                // full-width line), a fixed-height columns row
                                // (fixed so the live Switch/SpinBox cannot
                                // balloon into spare vertical space, user
                                // screenshot 2026-07-20), then the wrapping
                                // "what to do" line.
                                for row in root.compat-rows: VerticalLayout {
                                    spacing: 1px;
                                    padding-bottom: 8px;
                                    Text {
                                        text: row.game;
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Theme.text-color;
                                        overflow: elide;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        height: 30px;
                                        Text {
                                            width: 118px;
                                            text: row.how;
                                            font-size: 12px;
                                            color: Theme.muted-text-color;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            width: 60px;
                                            text: row.native-tf;
                                            font-size: 12px;
                                            color: Theme.muted-text-color;
                                            vertical-alignment: center;
                                        }
                                        // The "Simulated TF" cell: live for
                                        // rows carrying a tf-sim game id
                                        // (toggle + per-game intensity
                                        // writing tf-sim.conf), static text
                                        // otherwise.
                                        if row.sim-id == "": Text {
                                            width: 175px;
                                            text: row.tf;
                                            font-size: 12px;
                                            color: Theme.muted-text-color;
                                            vertical-alignment: center;
                                        }
                                        if row.sim-id != "": HorizontalLayout {
                                            // Fluent SpinBox min-width is
                                            // 112px; the cell must be wide
                                            // enough for Switch+SpinBox so
                                            // it does not spill past the
                                            // panel edge (user screenshot
                                            // 2026-07-20).
                                            width: 175px;
                                            spacing: 4px;
                                            Switch {
                                                checked: row.sim-enabled;
                                                toggled => { root.sim-game-enabled(row.sim-id, self.checked); }
                                            }
                                            SpinBox {
                                                horizontal-stretch: 1;
                                                minimum: 0;
                                                maximum: 100;
                                                value: row.sim-intensity;
                                                enabled: row.sim-enabled;
                                                edited(v) => { root.sim-game-intensity(row.sim-id, v); }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }
                                    // The one-line recommended setup, spanning
                                    // the full panel width so it wraps
                                    // readably instead of being squeezed into
                                    // a narrow column.
                                    Text {
                                        text: row.setup;
                                        font-size: 11px;
                                        color: Theme.muted-text-color;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    // Right column: the per-game shim manager and the installer's
                    // output.
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: Theme.gutter;

                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "TrueForce shim per game";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "Installs Logitech's signed TrueForce/Wheel SDK DLLs into a game's Proton prefix so SDK sims (ACC, AC EVO) get TrueForce. Uses the real DLLs, no injection.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                                // Compact toolbar between the description and
                                // the games list: the Rescan button at its
                                // natural size on the left, the installer's
                                // resolved path filling the rest of the row.
                                // The Text is the only stretching child, so
                                // the Button never grows past its own size,
                                // and the row is exactly one control tall.
                                HorizontalLayout {
                                    spacing: 8px;

                                    Button {
                                        text: "Rescan";
                                        enabled: !root.shim-running;
                                        clicked => { root.rescan-games(); }
                                    }
                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.shim-found
                                            ? "Installer: " + root.shim-path
                                            : "Installer: not found (PATH or the repo's tools/ directory)";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        color: root.shim-found ? Theme.muted-text-color : Theme.error-color;
                                        overflow: elide;
                                    }
                                }

                                if root.games-scanned && root.games.length == 0: Text {
                                    text: "No Steam installation with Proton games found. Install a game that runs through Proton, then press Rescan.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }

                                ListView {
                                    // The panel's only stretching child: it soaks
                                    // up whatever height the column has to spare
                                    // (the panel is stretched to the left column's
                                    // height), so the title/description/toolbar
                                    // rows above keep their natural heights packed
                                    // at the top instead of being spread apart.
                                    // The minimum keeps a visible box on an empty
                                    // scan; a huge library scrolls inside.
                                    vertical-stretch: 1;
                                    min-height: 144px;
                                    for game in root.games: Rectangle {
                                        height: 36px;

                                        HorizontalLayout {
                                            padding-right: 8px;
                                            spacing: 8px;

                                            Text {
                                                horizontal-stretch: 1;
                                                text: game.name;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                color: Theme.text-color;
                                            }
                                            Text {
                                                text: game.installed ? "shim installed" : "-";
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                color: game.installed ? Theme.ok-color : Theme.muted-text-color;
                                            }
                                            Button {
                                                width: 90px;
                                                text: game.installed ? "Remove" : "Install";
                                                enabled: !root.shim-running;
                                                clicked => {
                                                    if (game.installed) {
                                                        root.remove-game(game.prefix);
                                                    } else {
                                                        root.install-game(game.prefix);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        output-edit := TextEdit {
                            height: 110px;
                            read-only: true;
                            wrap: word-wrap;
                            text: root.shim-output;
                        }

                        // Section: Simulated TrueForce (the logi-tf-sim
                        // daemon). Master switch + intensity/pitch write
                        // tf-sim.conf; the per-game cells live in the
                        // compatibility table on the left.
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Simulated TrueForce (logi-tf-sim)";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "Synthesizes TrueForce engine haptics from a game's own UDP telemetry, for titles without native TrueForce. The daemon listens in the background and streams only while a supported game sends telemetry.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.tf-found
                                        ? "logi-tf-sim: found: " + root.tf-path
                                        : "logi-tf-sim: not found (PATH or next to this app)";
                                    font-size: 12px;
                                    color: root.tf-found ? Theme.text-color : Theme.error-color;
                                    wrap: word-wrap;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.tf-running ? "Daemon: running" : "Daemon: stopped";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        color: root.tf-running ? Theme.ok-color : Theme.muted-text-color;
                                    }
                                    Button {
                                        text: "Start";
                                        enabled: root.tf-found && !root.tf-running;
                                        clicked => { root.tf-start-daemon(); }
                                    }
                                    Button {
                                        text: "Stop";
                                        enabled: root.tf-running;
                                        clicked => { root.tf-stop-daemon(); }
                                    }
                                }
                                Switch {
                                    text: "Enabled (master switch)";
                                    checked: root.tf-enabled;
                                    toggled => { root.tf-set-enabled(self.checked); }
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        width: 60px;
                                        text: "Intensity";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        color: Theme.text-color;
                                    }
                                    intensity-slider := Slider {
                                        horizontal-stretch: 1;
                                        minimum: 0;
                                        maximum: 100;
                                        value: root.tf-intensity;
                                        // Committed on release, not on every
                                        // drag tick, same rule as the
                                        // settings sliders.
                                        released(v) => { root.tf-set-intensity(round(v)); }
                                    }
                                    Text {
                                        width: 36px;
                                        text: round(intensity-slider.value) + "%";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        horizontal-alignment: right;
                                        color: Theme.muted-text-color;
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        width: 60px;
                                        text: "Pitch";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        color: Theme.text-color;
                                    }
                                    pitch-slider := Slider {
                                        horizontal-stretch: 1;
                                        minimum: 10;
                                        maximum: 200;
                                        value: root.tf-pitch;
                                        released(v) => { root.tf-set-pitch(round(v)); }
                                    }
                                    Text {
                                        width: 36px;
                                        text: round(pitch-slider.value) + "%";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        horizontal-alignment: right;
                                        color: Theme.muted-text-color;
                                    }
                                }
                                Text {
                                    text: "Pitch is the felt rev rate; 100 = crank speed.";
                                    font-size: 11px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Button {
                                        text: "Test simulated TrueForce";
                                        enabled: root.tf-found && !root.tf-sweep-running;
                                        clicked => { root.tf-confirm-open = true; }
                                    }
                                    Button {
                                        text: "Stop test";
                                        enabled: root.tf-sweep-running;
                                        clicked => { root.tf-sweep-stop(); }
                                    }
                                }
                                if root.tf-output != "": TextEdit {
                                    height: 70px;
                                    read-only: true;
                                    wrap: word-wrap;
                                    text: root.tf-output;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: start;
                    spacing: 6px;

                    Text {
                        text: "Documentation:";
                        vertical-alignment: center;
                        color: Theme.muted-text-color;
                    }
                    link := Text {
                        text: root.project-url;
                        vertical-alignment: center;
                        color: Palette.accent-background;
                        font-weight: 600;
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-url(root.project-url); }
                        }
                    }
                }
            }
        }
    }

    // The test sweep's consent dialog, painted over the whole page. The
    // sweep never fires without pressing Continue here (same discipline
    // as the Test page's simulation dialogs).
    if root.tf-confirm-open: Rectangle {
        background: Theme.scrim;

        // Swallow clicks outside the dialog panel.
        TouchArea { }

        Rectangle {
            width: min(parent.width - 40px, 420px);
            height: tf-panel-layout.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            tf-panel-layout := VerticalLayout {
                padding: 18px;
                spacing: 12px;

                Text {
                    text: "Test simulated TrueForce";
                    font-size: 15px;
                    font-weight: 700;
                    color: Theme.text-color;
                }
                Text {
                    text: "The wheel WILL produce haptic force for about 6 seconds. Keep hands relaxed. Continue?";
                    font-size: 13px;
                    color: Theme.text-color;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Button {
                        text: "Cancel";
                        clicked => { root.tf-confirm-open = false; }
                    }
                    Button {
                        text: "Continue";
                        primary: true;
                        clicked => {
                            root.tf-sweep();
                            root.tf-confirm-open = false;
                        }
                    }
                }
            }
        }
    }
}
