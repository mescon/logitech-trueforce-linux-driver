import { Button, LineEdit, TextEdit, ScrollView, Slider, SpinBox, Switch, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One row of the Setup page's "Your games" list, built on the Rust side
// (`bridge::setup_games`) from `logi_dd_core::launchers::discover` (Steam,
// Lutris, Heroic) matched against the compatibility registry; a game that
// registry does not know is only listed if it already has the shim
// installed. It carries the game's display name, which launcher reported
// it (`source`, e.g. "Steam"), the wine prefix the shim installer targets
// (empty for a native game), a one-line plain-English summary of what
// makes it best on this wheel, and the single enablement action the row
// offers (`action`, matching `bridge::ACTION_*`): install the TrueForce
// shim, launch with logi-ffb, toggle simulated TrueForce, or works out of
// the box. `installed` reflects the shim marker DLL (shim action);
// `sim-id`/`sim-enabled`/`sim-intensity` carry the live tf-sim.conf state
// (simulated-TrueForce action).
export struct SetupGame {
    name: string,
    source: string,
    prefix: string,
    summary: string,
    action: int,
    installed: bool,
    sim-id: string,
    sim-enabled: bool,
    sim-intensity: int,
}

// One entry in the "Add a game" dialog's picker: a discovered Wine game the
// compatibility registry does not recognise and that is not shimmed yet
// (`bridge::addable_games`). `prefix` is the shim installer's target.
export struct AddableGame {
    name: string,
    source: string,
    prefix: string,
}

// One collapsible Setup section: a clickable header row (title + a short
// muted status/summary on the right + a chevron that points right when
// closed and down when open) with the section body shown only while
// `open`. Each section keeps its own `open` state, so several may be open
// at once (independent toggles, not a single-open accordion). The body is
// whatever elements the caller nests inside (`@children`), padded and
// stacked. The header is keyboard-usable: it is a `FocusScope`, so Tab
// reaches it and Enter/Space toggle the section, with a focus ring while
// it holds focus; a `TouchArea` handles the click (and takes focus first,
// so the keyboard and the mouse agree on which section is active).
component AccordionSection inherits Rectangle {
    in property <string> title;
    in property <string> summary;
    // Colours the summary with the error brush (a "not found" state that
    // wants to stand out) instead of the muted brush.
    in property <bool> summary-alert: false;
    in-out property <bool> open: false;

    background: Theme.panel-background;
    border-radius: Theme.panel-radius;
    border-width: 1px;
    border-color: Theme.panel-border;

    VerticalLayout {
        // The header row: click, or Enter/Space while focused, toggles the
        // section open/closed.
        Rectangle {
            fs := FocusScope {
                key-pressed(event) => {
                    if (event.text == Key.Return || event.text == Key.Space) {
                        root.open = !root.open;
                        return EventResult.accept;
                    }
                    return EventResult.reject;
                }
                HorizontalLayout {
                    padding: 14px;
                    spacing: 8px;
                    Text {
                        text: root.title;
                        font-size: 15px;
                        font-weight: 700;
                        color: Theme.text-color;
                        vertical-alignment: center;
                    }
                    Text {
                        horizontal-stretch: 1;
                        text: root.summary;
                        font-size: 12px;
                        color: root.summary-alert ? Theme.error-color : Theme.muted-text-color;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    // Chevron: right (closed), down (open).
                    Text {
                        text: root.open ? "\u{25BE}" : "\u{25B8}";
                        font-size: 14px;
                        color: Theme.muted-text-color;
                        vertical-alignment: center;
                    }
                }
            }
            // The keyboard focus ring, drawn only while the header holds
            // focus so the tab target is obvious.
            Rectangle {
                border-width: fs.has-focus ? 2px : 0px;
                border-color: Palette.accent-background;
                border-radius: Theme.panel-radius;
            }
            TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    fs.focus();
                    root.open = !root.open;
                }
            }
        }
        // The body collapses by clipping to zero height when closed (Slint
        // forbids `@children` inside a conditional element, so the body is
        // always built and the height gates it). `body`'s intrinsic
        // preferred-height drives the open height, so the section grows to
        // exactly fit whatever the caller nested inside.
        Rectangle {
            clip: true;
            height: root.open ? body.preferred-height : 0px;
            body := VerticalLayout {
                padding: 14px;
                spacing: 8px;
                @children
            }
        }
    }
}

// The sidebar's "Setup" page: an action panel for getting the best force
// feedback out of each installed game, laid out as an accordion. The
// "Force feedback vs TrueForce" primer stays open at the top as the
// orientation; below it a stack of collapsible sections (Your games open
// by default, then the logi-ffb helper, the TrueForce files folder, and
// the Simulated TrueForce daemon) each toggle independently; a link to
// the full compatibility list in the project wiki stays at the bottom.
// Shown instead of the settings list whenever `App.selected-category`
// equals `App.setup-index` (see `app.slint`'s content area). Nothing here
// is a device setting, so nothing goes through `Category`/`SettingRow`;
// the Rust side (`main.rs`) wires the callbacks directly to `std::process`
// calls, off the UI thread for the shim installer and the Steam scan.
export component Setup inherits Rectangle {
    in property <string> project-url: "";
    in property <bool> ffb-found: false;
    // The resolved helper paths ("" while not found): a PATH hit, or the
    // repo-checkout fallback (logi-ffb next to the app binary, the
    // installer in tools/ above it).
    in property <string> ffb-path: "";
    in property <bool> shim-found: false;
    in property <string> shim-path: "";
    in property <bool> shim-running: false;
    in property <string> shim-output: "";
    // The SDK folder field's initial text ($LOGITECH_TRUEFORCE_SDK_DIR,
    // else the XDG default) plus the resolution outcome: `sdk-status` is
    // the concrete answer ("SDK DLLs: found at <path>" or a not-found
    // line) the Rust side recomputes on page load and on every
    // edit-accept, resolving in the installer's own order (field, env
    // var, repo sdk/, XDG default); `sdk-valid` colors it green/red.
    in property <string> sdk-dir: "";
    in property <bool> sdk-valid: false;
    in property <string> sdk-status: "";
    // The installed Proton games, matched to the compatibility registry
    // and scanned off the UI thread at startup and after every
    // install/remove/rescan; `games-scanned` gates the empty state so "no
    // Steam found" never flashes before the first scan lands.
    // `games-summary` is the header's one-line count (built in Rust
    // alongside the list; see `bridge::games_summary`).
    in property <[SetupGame]> games: [];
    in property <bool> games-scanned: false;
    in property <string> games-summary: "";
    // The "Add a game" dialog's picker list: Wine games the launcher scan
    // found but the compatibility registry does not recognise, and that are
    // not shimmed yet (see `bridge::addable_games`).
    in property <[AddableGame]> addable-games: [];
    // Fired by the dialog's confirm button with the chosen (or typed) wine
    // prefix; runs the same shim install the per-game button above runs.
    callback add-game(string);
    private property <bool> add-game-open: false;
    // Index into `addable-games` of the picked entry, or -1 while nothing
    // is picked (typing in the manual prefix field clears this back to -1).
    private property <int> add-game-selected: -1;
    private property <string> add-game-manual-prefix: "";
    // Simulated TrueForce (the logi-tf-sim daemon): the resolved binary
    // ("" while not found), whether the daemon is running, the master
    // switch/intensity/pitch from tf-sim.conf, and the test sweep's
    // run state + surfaced output.
    in property <bool> tf-found: false;
    in property <string> tf-path: "";
    in property <bool> tf-running: false;
    in property <bool> tf-enabled: false;
    in property <int> tf-intensity: 60;
    in property <int> tf-pitch: 100;
    in property <bool> tf-sweep-running: false;
    in property <string> tf-output: "";
    // The test sweep's consent dialog; the sweep only ever fires from its
    // Continue button, same discipline as the Test page's simulations.
    private property <bool> tf-confirm-open: false;

    // The accordion sections' open/closed state. Your games leads open (it
    // is the main task); the three global helpers start closed. Multiple
    // may be open at once.
    private property <bool> games-open: true;
    private property <bool> ffb-open: false;
    private property <bool> sdk-open: false;
    private property <bool> simtf-open: false;

    // The action tags a `SetupGame.action` carries; kept in sync with
    // `bridge::ACTION_*`. Named here so the per-game row's `if` branches
    // read as intent, not magic numbers.
    private property <int> action-shim: 0;
    private property <int> action-logi-ffb: 1;
    private property <int> action-sim-tf: 2;
    private property <int> action-out-of-box: 3;

    // The full game-compatibility list now lives in the project wiki; the
    // page links there instead of carrying a static table.
    private property <string> wiki-url: "https://github.com/mescon/logitech-trueforce-linux-driver/wiki/Force-Feedback-in-Games";

    // Copies "logi-ffb %command%" to the clipboard (best-effort, wl-copy
    // then xclip; the field next to the button is selectable as a fallback).
    callback copy-launch();
    // The SDK folder field's edit-accept: re-runs the full resolution and
    // pushes the fresh outcome back into `sdk-status`/`sdk-valid`.
    // Installs pass the RESOLVED directory explicitly (--sdk-dir), so what
    // the status line reports is exactly what an install uses.
    callback sdk-dir-edited(string);
    // Per-game shim runs, off the UI thread; the argument is the row's
    // wine prefix path. `shim-output` and `shim-running` are pushed back
    // once the run finishes, followed by a rescan.
    callback install-game(string);
    callback remove-game(string);
    callback rescan-games();
    // Opens a URL in the user's browser; wired to the same `open-url`
    // callback the Info category's link uses.
    callback open-url(string);
    // Simulated TrueForce edits, all writing tf-sim.conf on the Rust
    // side (one key per call, so hand-added lines survive).
    callback tf-set-enabled(bool);
    callback tf-set-intensity(int);
    callback tf-set-pitch(int);
    callback tf-start-daemon();
    callback tf-stop-daemon();
    // Fired only from the consent dialog's Continue button: runs
    // `logi-tf-sim --sweep` (about 6 s of real haptics) off the UI thread.
    callback tf-sweep();
    // SIGTERMs the running sweep so it stops cleanly (stop packets sent).
    callback tf-sweep-stop();
    // A game row's live simulated-TrueForce cell: the row's tf-sim game id
    // plus the new value.
    callback sim-game-enabled(string, bool);
    callback sim-game-intensity(string, int);

    background: transparent;

    VerticalLayout {
        spacing: Theme.gutter;

        Text {
            text: "Setup";
            font-size: 20px;
            font-weight: 700;
            color: Theme.text-color;
        }

        // Plain-English primer on the two things this page sets up. Most
        // users have never been told the difference, so it leads the page
        // and always stays visible (it is the orientation, not a section).
        Rectangle {
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            VerticalLayout {
                padding: 14px;
                spacing: 6px;

                Text {
                    text: "Force feedback vs TrueForce";
                    font-size: 15px;
                    font-weight: 700;
                    color: Theme.text-color;
                }
                Text {
                    text: "Force feedback is the physical force on the wheel: the weight of the car, the pull of the road, kerbs and impacts. Every game with wheel support has it, and it works with no setup.";
                    font-size: 12px;
                    color: Theme.muted-text-color;
                    wrap: word-wrap;
                }
                Text {
                    text: "TrueForce is Logitech's extra detail on top: fine high-frequency vibration driven by the game's engine and surfaces (engine growl, tyre scrub, road texture). Some games have it built in; for the rest, this app can simulate it from the game's live telemetry.";
                    font-size: 12px;
                    color: Theme.muted-text-color;
                    wrap: word-wrap;
                }
            }
        }

        // The accordion scrolls as a whole, with the scrollbar always
        // visible so it is obvious more is below; the viewport is pinned to
        // the visible width so nothing scrolls sideways. Every section
        // fills the full content width.
        ScrollView {
            vertical-stretch: 1;
            viewport-width: self.visible-width;
            vertical-scrollbar-policy: always-on;

            VerticalLayout {
                spacing: Theme.gutter;

                // Section: "Your games", the per-game action list, open by
                // default. One row per installed Steam/Proton game, matched
                // to the compatibility registry, showing only the controls
                // that game needs.
                AccordionSection {
                    title: "Your games";
                    summary: root.games-scanned ? root.games-summary : "scanning...";
                    open <=> root.games-open;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            horizontal-stretch: 1;
                            text: "Your installed Steam games that run through Proton, and what each one needs to feel its best on this wheel.";
                            font-size: 12px;
                            color: Theme.muted-text-color;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }
                        Button {
                            text: "Add a game";
                            enabled: !root.shim-running;
                            clicked => { root.add-game-open = true; }
                        }
                        Button {
                            text: "Rescan";
                            enabled: !root.shim-running;
                            clicked => { root.rescan-games(); }
                        }
                    }

                    if root.games-scanned && root.games.length == 0: Text {
                        text: "No Steam games that run through Proton were found. Install one, then press Rescan.";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                        wrap: word-wrap;
                    }
                    if !root.games-scanned: Text {
                        text: "Scanning your Steam library...";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                    }

                    for game in root.games: Rectangle {
                        background: Theme.control-background;
                        border-radius: Theme.panel-radius;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;

                            // Name on its own full-width line so long
                            // titles never elide next to the controls, with
                            // the launcher that found it as a small muted
                            // tag alongside.
                            HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    horizontal-stretch: 1;
                                    text: game.name;
                                    font-size: 14px;
                                    font-weight: 600;
                                    color: Theme.text-color;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: game.source;
                                    font-size: 11px;
                                    color: Theme.muted-text-color;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: game.summary;
                                font-size: 12px;
                                color: Theme.muted-text-color;
                                wrap: word-wrap;
                            }

                            // Install / remove the TrueForce shim (games
                            // with built-in TrueForce).
                            if game.action == root.action-shim: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    horizontal-stretch: 1;
                                    text: game.installed
                                        ? "TrueForce files installed for this game"
                                        : "TrueForce files not installed yet";
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    color: game.installed ? Theme.ok-color : Theme.muted-text-color;
                                }
                                Button {
                                    text: game.installed ? "Remove TrueForce" : "Install TrueForce";
                                    enabled: !root.shim-running;
                                    clicked => {
                                        if (game.installed) {
                                            root.remove-game(game.prefix);
                                        } else {
                                            root.install-game(game.prefix);
                                        }
                                    }
                                }
                            }

                            // Older DirectInput game: launch it with
                            // logi-ffb.
                            if game.action == root.action-logi-ffb: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "Steam launch options:";
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    color: Theme.muted-text-color;
                                }
                                LineEdit {
                                    horizontal-stretch: 1;
                                    text: "logi-ffb %command%";
                                    read-only: true;
                                }
                                Button {
                                    text: "Copy";
                                    clicked => { root.copy-launch(); }
                                }
                            }

                            // Simulated TrueForce: the game's own switch
                            // + strength, writing tf-sim.conf.
                            if game.action == root.action-sim-tf: HorizontalLayout {
                                spacing: 8px;
                                Switch {
                                    text: "Simulated TrueForce";
                                    checked: game.sim-enabled;
                                    toggled => { root.sim-game-enabled(game.sim-id, self.checked); }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Text {
                                    text: "Strength";
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    color: game.sim-enabled ? Theme.text-color : Theme.muted-text-color;
                                }
                                SpinBox {
                                    minimum: 0;
                                    maximum: 100;
                                    value: game.sim-intensity;
                                    enabled: game.sim-enabled;
                                    edited(v) => { root.sim-game-intensity(game.sim-id, v); }
                                }
                            }

                            // Native force feedback, nothing to install.
                            if game.action == root.action-out-of-box: Text {
                                text: "Force feedback works out of the box.";
                                font-size: 12px;
                                color: Theme.ok-color;
                            }
                        }
                    }

                    if root.shim-output != "": TextEdit {
                        height: 90px;
                        read-only: true;
                        wrap: word-wrap;
                        text: root.shim-output;
                    }
                }

                // Section: logi-ffb (force feedback for older DirectInput
                // games run through Proton).
                AccordionSection {
                    title: "Force feedback helper (logi-ffb)";
                    summary: root.ffb-found ? "found" : "not found";
                    summary-alert: !root.ffb-found;
                    open <=> root.ffb-open;

                    Text {
                        text: "Games that use the older DirectInput force-feedback method (for example Le Mans Ultimate) get no force feedback through Proton by default. Launching them with the logi-ffb helper gives them force feedback through a virtual wheel.";
                        color: Theme.muted-text-color;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    Text {
                        text: root.ffb-found
                            ? "logi-ffb: found: " + root.ffb-path
                            : "logi-ffb: not found (on your PATH or next to this app)";
                        font-size: 12px;
                        color: root.ffb-found ? Theme.text-color : Theme.error-color;
                        wrap: word-wrap;
                    }
                    Text {
                        text: "Add this to the game's Steam launch options:";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            horizontal-stretch: 1;
                            text: "logi-ffb %command%";
                            read-only: true;
                        }
                        Button {
                            text: "Copy";
                            clicked => { root.copy-launch(); }
                        }
                    }
                }

                // Section: the TrueForce SDK folder + libtrueforce note.
                AccordionSection {
                    title: "TrueForce files";
                    summary: root.sdk-valid ? "found" : "not found";
                    summary-alert: !root.sdk-valid;
                    open <=> root.sdk-open;

                    Text {
                        text: "Games with built-in TrueForce (like ACC and AC EVO) need Logitech's TrueForce files installed into their Proton folder. Point this at the folder holding those files; the per-game buttons above then use it.";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                        wrap: word-wrap;
                    }
                    LineEdit {
                        text: root.sdk-dir;
                        placeholder-text: "Path to your Logitech TrueForce files";
                        accepted(text) => { root.sdk-dir-edited(text); }
                    }
                    // The concrete resolution outcome: green "found at
                    // <path>", or a red not-found line (the files must be
                    // copied from a Windows G HUB install first).
                    Text {
                        text: root.sdk-status;
                        font-size: 12px;
                        color: root.sdk-valid ? Theme.ok-color : Theme.error-color;
                        wrap: word-wrap;
                    }
                    Text {
                        text: "The TrueForce files come from Logitech's G HUB install on Windows and are never redistributed; the project README explains how to copy them here. Native Linux apps can also drive TrueForce through this project's libtrueforce library.";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                        wrap: word-wrap;
                    }
                }

                // Section: Simulated TrueForce (the logi-tf-sim daemon).
                // Master switch + intensity/pitch write tf-sim.conf; the
                // per-game switches live in each game's row above.
                AccordionSection {
                    title: "Simulated TrueForce (logi-tf-sim)";
                    summary: root.tf-enabled ? "on" : "off";
                    open <=> root.simtf-open;

                    Text {
                        text: "Creates TrueForce-style engine vibration from a game's own telemetry, for games without built-in TrueForce. The background helper listens quietly and only sends vibration while a supported game is streaming its telemetry. Turn it on for individual games in the list above.";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                        wrap: word-wrap;
                    }
                    Text {
                        text: root.tf-found
                            ? "logi-tf-sim: found: " + root.tf-path
                            : "logi-tf-sim: not found (on your PATH or next to this app)";
                        font-size: 12px;
                        color: root.tf-found ? Theme.text-color : Theme.error-color;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            horizontal-stretch: 1;
                            text: root.tf-running ? "Background helper: running" : "Background helper: stopped";
                            font-size: 12px;
                            vertical-alignment: center;
                            color: root.tf-running ? Theme.ok-color : Theme.muted-text-color;
                        }
                        Button {
                            text: "Start";
                            enabled: root.tf-found && !root.tf-running;
                            clicked => { root.tf-start-daemon(); }
                        }
                        Button {
                            text: "Stop";
                            enabled: root.tf-running;
                            clicked => { root.tf-stop-daemon(); }
                        }
                    }
                    Switch {
                        text: "Simulated TrueForce on (master switch)";
                        checked: root.tf-enabled;
                        toggled => { root.tf-set-enabled(self.checked); }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            width: 70px;
                            text: "Strength";
                            font-size: 12px;
                            vertical-alignment: center;
                            color: Theme.text-color;
                        }
                        intensity-slider := Slider {
                            horizontal-stretch: 1;
                            minimum: 0;
                            maximum: 100;
                            value: root.tf-intensity;
                            // Committed on release, not on every drag
                            // tick, same rule as the settings sliders.
                            released(v) => { root.tf-set-intensity(round(v)); }
                        }
                        Text {
                            width: 36px;
                            text: round(intensity-slider.value) + "%";
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                            color: Theme.muted-text-color;
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            width: 70px;
                            text: "Rev rate";
                            font-size: 12px;
                            vertical-alignment: center;
                            color: Theme.text-color;
                        }
                        pitch-slider := Slider {
                            horizontal-stretch: 1;
                            minimum: 10;
                            maximum: 200;
                            value: root.tf-pitch;
                            released(v) => { root.tf-set-pitch(round(v)); }
                        }
                        Text {
                            width: 36px;
                            text: round(pitch-slider.value) + "%";
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                            color: Theme.muted-text-color;
                        }
                    }
                    Text {
                        text: "Rev rate is how fast the felt engine buzz rises with the revs; 100% tracks the engine speed.";
                        font-size: 11px;
                        color: Theme.muted-text-color;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "Test simulated TrueForce";
                            enabled: root.tf-found && !root.tf-sweep-running;
                            clicked => { root.tf-confirm-open = true; }
                        }
                        Button {
                            text: "Stop test";
                            enabled: root.tf-sweep-running;
                            clicked => { root.tf-sweep-stop(); }
                        }
                    }
                    if root.tf-output != "": TextEdit {
                        height: 70px;
                        read-only: true;
                        wrap: word-wrap;
                        text: root.tf-output;
                    }
                }

                // The full compatibility list lives in the wiki now; this
                // link stays at the bottom, always visible.
                HorizontalLayout {
                    alignment: start;
                    spacing: 6px;

                    Text {
                        text: "Full game compatibility list:";
                        vertical-alignment: center;
                        color: Theme.muted-text-color;
                    }
                    Text {
                        text: "project wiki";
                        vertical-alignment: center;
                        color: Palette.accent-background;
                        font-weight: 600;
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-url(root.wiki-url); }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: start;
                    spacing: 6px;

                    Text {
                        text: "Documentation:";
                        vertical-alignment: center;
                        color: Theme.muted-text-color;
                    }
                    link := Text {
                        text: root.project-url;
                        vertical-alignment: center;
                        color: Palette.accent-background;
                        font-weight: 600;
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-url(root.project-url); }
                        }
                    }
                }
            }
        }
    }

    // The test sweep's consent dialog, painted over the whole page. The
    // sweep never fires without pressing Continue here (same discipline
    // as the Test page's simulation dialogs).
    if root.tf-confirm-open: Rectangle {
        background: Theme.scrim;

        // Swallow clicks outside the dialog panel.
        TouchArea { }

        Rectangle {
            width: min(parent.width - 40px, 420px);
            height: tf-panel-layout.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            tf-panel-layout := VerticalLayout {
                padding: 18px;
                spacing: 12px;

                Text {
                    text: "Test simulated TrueForce";
                    font-size: 15px;
                    font-weight: 700;
                    color: Theme.text-color;
                }
                Text {
                    text: "The wheel WILL produce haptic force for about 6 seconds. Keep hands relaxed. Continue?";
                    font-size: 13px;
                    color: Theme.text-color;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Button {
                        text: "Cancel";
                        clicked => { root.tf-confirm-open = false; }
                    }
                    Button {
                        text: "Continue";
                        primary: true;
                        clicked => {
                            root.tf-sweep();
                            root.tf-confirm-open = false;
                        }
                    }
                }
            }
        }
    }

    // "Add a game" dialog: lets the user point the shim installer at a Wine
    // prefix the launcher scan did not recognise, either by picking one of
    // the discovered-but-unrecognised games or by typing a prefix directly.
    // Confirm runs the same TrueForce-files install the per-game button
    // above runs; a rescan afterwards picks the game back up into "Your
    // games" once its shim is installed.
    if root.add-game-open: Rectangle {
        background: Theme.scrim;

        // Swallow clicks outside the dialog panel, same as the sweep
        // consent dialog above.
        TouchArea { }

        Rectangle {
            width: min(parent.width - 40px, 460px);
            height: min(add-game-layout.preferred-height, parent.height - 40px);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.panel-background;
            border-radius: Theme.panel-radius;
            border-width: 1px;
            border-color: Theme.panel-border;

            add-game-layout := VerticalLayout {
                padding: 18px;
                spacing: 10px;

                Text {
                    text: "Add a game";
                    font-size: 15px;
                    font-weight: 700;
                    color: Theme.text-color;
                }
                Text {
                    text: "Have a racing sim we do not recognise? Pick it here to install the TrueForce files into its prefix. If it uses Logitech's TrueForce SDK you get TrueForce; if not, the files sit unused and do no harm.";
                    font-size: 12px;
                    color: Theme.muted-text-color;
                    wrap: word-wrap;
                }

                if root.addable-games.length > 0: VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Discovered but not recognised:";
                        font-size: 12px;
                        color: Theme.muted-text-color;
                    }
                    ScrollView {
                        height: min(140px, picker.preferred-height);
                        viewport-width: self.visible-width;
                        picker := VerticalLayout {
                            spacing: 2px;
                            for g[i] in root.addable-games: Rectangle {
                                background: i == root.add-game-selected ? Theme.selected-background : Theme.control-background;
                                border-radius: Theme.panel-radius;

                                Text {
                                    text: g.name + " (" + g.source + ")";
                                    font-size: 12px;
                                    color: i == root.add-game-selected ? Theme.selected-foreground : Theme.text-color;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    overflow: elide;
                                }

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.add-game-selected = i;
                                        root.add-game-manual-prefix = "";
                                    }
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "Or point at a Wine prefix:";
                    font-size: 12px;
                    color: Theme.muted-text-color;
                }
                LineEdit {
                    text: root.add-game-manual-prefix;
                    placeholder-text: "/path/to/steamapps/compatdata/<id>/pfx";
                    edited(text) => {
                        root.add-game-manual-prefix = text;
                        root.add-game-selected = -1;
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Button {
                        text: "Cancel";
                        clicked => {
                            root.add-game-open = false;
                            root.add-game-selected = -1;
                            root.add-game-manual-prefix = "";
                        }
                    }
                    Button {
                        text: "Install TrueForce files";
                        primary: true;
                        enabled: root.add-game-selected >= 0 || root.add-game-manual-prefix != "";
                        clicked => {
                            root.add-game(
                                root.add-game-selected >= 0
                                    ? root.addable-games[root.add-game-selected].prefix
                                    : root.add-game-manual-prefix
                            );
                            root.add-game-open = false;
                            root.add-game-selected = -1;
                            root.add-game-manual-prefix = "";
                        }
                    }
                }
            }
        }
    }
}
