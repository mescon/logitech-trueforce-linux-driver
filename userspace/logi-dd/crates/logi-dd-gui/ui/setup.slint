import { Button, LineEdit, TextEdit, ListView, ScrollView, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One row of the Setup page's Proton games list, built on the Rust side
// from `logi_dd_core::steam::installed_games`: the game's display name,
// the wine prefix path the installer targets, and whether the shim's
// marker DLL is present in it.
export struct SetupGame {
    name: string,
    prefix: string,
    installed: bool,
}

// One static row of the compatibility table: the game, how force feedback
// reaches it today, and where it stands with the upcoming per-game
// "Simulate TrueForce" option ("planned" for FFB-only titles, "n/a
// (native)" where the shim already delivers real TrueForce).
struct CompatRow {
    game: string,
    how: string,
    tf: string,
}

// The sidebar's "Setup" page: the DirectInput FFB proxy (logi-ffb), the
// TrueForce SDK folder + per-game shim management, and a documentation
// link, shown instead of the settings list whenever `App.selected-category`
// equals `App.setup-index` (see `app.slint`'s content area). Nothing here
// is a device setting, so nothing goes through `Category`/`SettingRow`; the
// Rust side (`main.rs`) wires the callbacks directly to `std::process`
// calls, off the UI thread for the shim installer and the Steam scan.
export component Setup inherits Rectangle {
    in property <string> project-url: "";
    in property <bool> ffb-found: false;
    // The resolved helper paths ("" while not found): a PATH hit, or the
    // repo-checkout fallback (logi-ffb next to the app binary, the
    // installer in tools/ above it).
    in property <string> ffb-path: "";
    in property <bool> shim-found: false;
    in property <string> shim-path: "";
    in property <bool> shim-running: false;
    in property <string> shim-output: "";
    // The SDK folder field's initial text ($LOGITECH_TRUEFORCE_SDK_DIR,
    // else the XDG default) plus the resolution outcome: `sdk-status` is
    // the concrete answer ("SDK DLLs: found at <path>" or a not-found
    // line) the Rust side recomputes on page load and on every
    // edit-accept, resolving in the installer's own order (field, env
    // var, repo sdk/, XDG default); `sdk-valid` colors it green/red.
    in property <string> sdk-dir: "";
    in property <bool> sdk-valid: false;
    in property <string> sdk-status: "";
    // The installed Proton games, scanned off the UI thread at startup and
    // after every install/remove/rescan; `games-scanned` gates the empty
    // state so "no Steam found" never flashes before the first scan lands.
    in property <[SetupGame]> games: [];
    in property <bool> games-scanned: false;

    // Copies "logi-ffb %command%" to the clipboard (best-effort, wl-copy
    // then xclip; the field next to the button is selectable as a fallback).
    callback copy-launch();
    // The SDK folder field's edit-accept: re-runs the full resolution and
    // pushes the fresh outcome back into `sdk-status`/`sdk-valid`.
    // Installs pass the RESOLVED directory explicitly (--sdk-dir), so what
    // the status line reports is exactly what an install uses.
    callback sdk-dir-edited(string);
    // Per-game shim runs, off the UI thread; the argument is the row's
    // wine prefix path. `shim-output` and `shim-running` are pushed back
    // once the run finishes, followed by a rescan.
    callback install-game(string);
    callback remove-game(string);
    callback rescan-games();
    // Opens `project-url` in the user's browser; wired to the same
    // `open-url` callback the Info category's link uses.
    callback open-url(string);

    // A trailing "*" marks titles not verified on this driver yet
    // (expected to work: their input stack is one the helpers already
    // cover); the note above the table says so.
    private property <[CompatRow]> compat-rows: [
        { game: "ACC", how: "TrueForce (shim)", tf: "n/a (native)" },
        { game: "AC EVO", how: "TrueForce (shim)", tf: "n/a (native)" },
        { game: "iRacing", how: "FFB (native)", tf: "planned" },
        { game: "Le Mans Ultimate", how: "FFB (logi-ffb)", tf: "planned" },
        { game: "Automobilista 2", how: "FFB (logi-ffb)", tf: "planned" },
        { game: "rFactor 2", how: "FFB (logi-ffb)", tf: "planned" },
        { game: "Assetto Corsa", how: "FFB (logi-ffb) *", tf: "planned" },
        { game: "Project CARS 2", how: "FFB (logi-ffb) *", tf: "planned" },
        { game: "Dirt Rally 2.0", how: "FFB (native)", tf: "planned" },
        { game: "EA SPORTS WRC", how: "FFB *", tf: "planned" },
        { game: "F1 series", how: "FFB *", tf: "planned" },
        { game: "ETS2 / ATS", how: "FFB (native Linux)", tf: "planned" },
        { game: "BeamNG.drive", how: "FFB (native)", tf: "planned" },
    ];

    background: transparent;

    VerticalLayout {
        spacing: Theme.gutter;

        Text {
            text: "Setup";
            font-size: 20px;
            font-weight: 700;
            color: Theme.text-color;
        }

        // The page content scrolls: at small window sizes (or with a long
        // games list) the columns are taller than the window, and without
        // a scroll surface the lower panels (e.g. Game compatibility) were
        // simply unreachable. Vertical-only: the viewport is pinned to the
        // visible width so the columns wrap instead of scrolling sideways.
        ScrollView {
            vertical-stretch: 1;
            viewport-width: self.visible-width;

            VerticalLayout {
                spacing: Theme.gutter;

                HorizontalLayout {
                    spacing: Theme.gutter;

                    // Left column: logi-ffb, the SDK folder + libtrueforce note,
                    // and the compatibility table.
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: Theme.gutter;

                        // Section: logi-ffb (DirectInput/Proton FFB proxy).
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Force feedback in games (logi-ffb)";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "DirectInput sims run through Proton (e.g. Le Mans Ultimate) do not get force feedback by default. Running the game through logi-ffb gives them FFB via a virtual wheel.";
                                    color: Theme.muted-text-color;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.ffb-found
                                        ? "logi-ffb: found: " + root.ffb-path
                                        : "logi-ffb: not found (PATH or next to this app)";
                                    font-size: 12px;
                                    color: root.ffb-found ? Theme.text-color : Theme.error-color;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "Add this to the game's Steam launch options:";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    LineEdit {
                                        horizontal-stretch: 1;
                                        text: "logi-ffb %command%";
                                        read-only: true;
                                    }
                                    Button {
                                        text: "Copy";
                                        clicked => { root.copy-launch(); }
                                    }
                                }
                            }
                        }

                        // Section: the TrueForce SDK folder + libtrueforce note.
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "TrueForce SDK folder";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                LineEdit {
                                    text: root.sdk-dir;
                                    placeholder-text: "Path to your Logitech SDK DLLs";
                                    accepted(text) => { root.sdk-dir-edited(text); }
                                }
                                // The concrete resolution outcome: green
                                // "found at <path>", or a red not-found
                                // line (the DLLs must be copied from a
                                // Windows G HUB install first).
                                Text {
                                    text: root.sdk-status;
                                    font-size: 12px;
                                    color: root.sdk-valid ? Theme.ok-color : Theme.error-color;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "Native Linux apps can also drive TrueForce through this project's libtrueforce library (userspace/libtrueforce). The SDK DLLs themselves come from Logitech's G HUB install on Windows and are never redistributed; the project README explains how to copy them here.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // Section: compatibility table (static reference).
                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 4px;

                                Text {
                                    text: "Game compatibility";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "\"FFB (logi-ffb)\" means launch with logi-ffb %command%. \"Simulated TF\" is an upcoming per-game option that synthesizes TrueForce for FFB-only titles; \"n/a (native)\" titles already get the real thing via the shim. * = expected to work, not verified on this driver yet.";
                                    font-size: 11px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                                // Header row, then one row per title. The
                                // middle column gets a fixed width so the
                                // three columns line up as a table.
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        horizontal-stretch: 1;
                                        text: "Game";
                                        font-size: 11px;
                                        font-weight: 600;
                                        color: Theme.muted-text-color;
                                    }
                                    Text {
                                        width: 130px;
                                        text: "Force feedback";
                                        font-size: 11px;
                                        font-weight: 600;
                                        color: Theme.muted-text-color;
                                    }
                                    Text {
                                        width: 80px;
                                        text: "Simulated TF";
                                        font-size: 11px;
                                        font-weight: 600;
                                        color: Theme.muted-text-color;
                                    }
                                }
                                for row in root.compat-rows: HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        horizontal-stretch: 1;
                                        text: row.game;
                                        font-size: 12px;
                                        color: Theme.text-color;
                                        overflow: elide;
                                    }
                                    Text {
                                        width: 130px;
                                        text: row.how;
                                        font-size: 12px;
                                        color: Theme.muted-text-color;
                                    }
                                    Text {
                                        width: 80px;
                                        text: row.tf;
                                        font-size: 12px;
                                        color: Theme.muted-text-color;
                                    }
                                }
                            }
                        }
                    }

                    // Right column: the per-game shim manager and the installer's
                    // output.
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: Theme.gutter;

                        Rectangle {
                            background: Theme.panel-background;
                            border-radius: Theme.panel-radius;
                            border-width: 1px;
                            border-color: Theme.panel-border;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "TrueForce shim per game";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: Theme.text-color;
                                }
                                Text {
                                    text: "Installs Logitech's signed TrueForce/Wheel SDK DLLs into a game's Proton prefix so SDK sims (ACC, AC EVO) get TrueForce. Uses the real DLLs, no injection.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }
                                // Compact toolbar between the description and
                                // the games list: the Rescan button at its
                                // natural size on the left, the installer's
                                // resolved path filling the rest of the row.
                                // The Text is the only stretching child, so
                                // the Button never grows past its own size,
                                // and the row is exactly one control tall.
                                HorizontalLayout {
                                    spacing: 8px;

                                    Button {
                                        text: "Rescan";
                                        enabled: !root.shim-running;
                                        clicked => { root.rescan-games(); }
                                    }
                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.shim-found
                                            ? "Installer: " + root.shim-path
                                            : "Installer: not found (PATH or the repo's tools/ directory)";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        color: root.shim-found ? Theme.muted-text-color : Theme.error-color;
                                        overflow: elide;
                                    }
                                }

                                if root.games-scanned && root.games.length == 0: Text {
                                    text: "No Steam installation with Proton games found. Install a game that runs through Proton, then press Rescan.";
                                    font-size: 12px;
                                    color: Theme.muted-text-color;
                                    wrap: word-wrap;
                                }

                                ListView {
                                    // The panel's only stretching child: it soaks
                                    // up whatever height the column has to spare
                                    // (the panel is stretched to the left column's
                                    // height), so the title/description/toolbar
                                    // rows above keep their natural heights packed
                                    // at the top instead of being spread apart.
                                    // The minimum keeps a visible box on an empty
                                    // scan; a huge library scrolls inside.
                                    vertical-stretch: 1;
                                    min-height: 144px;
                                    for game in root.games: Rectangle {
                                        height: 36px;

                                        HorizontalLayout {
                                            padding-right: 8px;
                                            spacing: 8px;

                                            Text {
                                                horizontal-stretch: 1;
                                                text: game.name;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                color: Theme.text-color;
                                            }
                                            Text {
                                                text: game.installed ? "shim installed" : "-";
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                color: game.installed ? Theme.ok-color : Theme.muted-text-color;
                                            }
                                            Button {
                                                width: 90px;
                                                text: game.installed ? "Remove" : "Install";
                                                enabled: !root.shim-running;
                                                clicked => {
                                                    if (game.installed) {
                                                        root.remove-game(game.prefix);
                                                    } else {
                                                        root.install-game(game.prefix);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        output-edit := TextEdit {
                            height: 110px;
                            read-only: true;
                            wrap: word-wrap;
                            text: root.shim-output;
                        }
                    }
                }

                HorizontalLayout {
                    alignment: start;
                    spacing: 6px;

                    Text {
                        text: "Documentation:";
                        vertical-alignment: center;
                        color: Theme.muted-text-color;
                    }
                    link := Text {
                        text: root.project-url;
                        vertical-alignment: center;
                        color: Palette.accent-background;
                        font-weight: 600;
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-url(root.project-url); }
                        }
                    }
                }
            }
        }
    }
}
