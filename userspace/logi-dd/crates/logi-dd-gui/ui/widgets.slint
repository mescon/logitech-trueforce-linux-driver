import { ListView, Slider, ComboBox, Switch, LineEdit, Button, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One rendered setting. `kind` is a stable numeric tag the Rust side and this
// file agree on (see `bridge::KIND_*` in `src/bridge.rs`):
//   0 = percent   (Slider, 0-100, "%" suffix)
//   1 = int range (Slider, `min`..`max`, `unit` suffix)
//   2 = enum      (ComboBox over `choices`, `int-value` is the index)
//   3 = toggle    (Switch, `bool-value`)
//   4 = text      (LineEdit, `text-value`)
//   5 = action    (Button, no value, fires `trigger`)
//   6 = readonly  (plain Text showing `display`; also used for kinds that do
//                  not have a dedicated live editor yet: the deadzone pair)
//   7 = curve     (Button that opens the curve editor overlay, fires
//                  `edit-curve`)
//   8 = rgb strip (Button that opens the RGB strip editor overlay, fires
//                  `edit-rgb`)
//   9 = slot text (Button that opens the slot-text editor overlay, fires
//                  `edit-slot-text`)
export struct SettingRow {
    attr: string,
    label: string,
    help: string,
    kind: int,
    int-value: int,
    bool-value: bool,
    text-value: string,
    display: string,
    choices: [string],
    min: int,
    max: int,
    step: int,
    unit: string,
    available: bool,
    mode-ok: bool,
    error: string,
}

export component SettingsList inherits ListView {
    in property <[SettingRow]> rows;

    callback edit-slider(string, int);
    callback edit-choice(string, int);
    callback edit-switch(string, bool);
    callback edit-text(string, string);
    callback trigger(string);
    // Fired by a curve row's "Edit curve" button (kind 7); the app opens the
    // curve editor overlay for `attr`, seeded from that row's current value.
    callback edit-curve(string);
    // Fired by an RGB strip row's "Edit colors" button (kind 8); the app
    // opens the RGB strip editor overlay for `attr`, seeded from that row's
    // current value.
    callback edit-rgb(string);
    // Fired by a slot-text row's "Edit slot names" button (kind 9); the app
    // opens the slot-text editor overlay for `attr`, seeded from that row's
    // current value.
    callback edit-slot-text(string);
    // Fired by the per-row "Switch mode" button, shown on a row whose
    // `mode-ok` is false. It does not say which mode: with exactly two
    // modes, whichever one the wheel is not currently in is the one this
    // row needs, so this just asks the app to flip it (same action as the
    // header's mode toggle).
    callback switch-mode();

    // Every row uses the same fixed three-column layout (label, control,
    // status), regardless of `kind`: column widths come from `Theme` so no
    // control's x position ever depends on what the row next to it is
    // showing (fixes controls jumping around between rows).
    for row in rows: Rectangle {
        min-height: Theme.row-height;

        HorizontalLayout {
            padding: Theme.gutter;
            spacing: Theme.gutter;

            // Column 1: label (bold) plus a smaller muted help line.
            VerticalLayout {
                width: Theme.label-column-width;
                alignment: center;
                spacing: 2px;

                Text {
                    text: row.label;
                    font-weight: 600;
                    color: Theme.text-color;
                    wrap: word-wrap;
                }
                Text {
                    text: row.help;
                    font-size: 11px;
                    color: Theme.muted-text-color;
                    wrap: word-wrap;
                }
            }

            // Column 2: the control itself. Exactly one branch is active
            // per row (see the `kind` doc comment above); every branch is
            // left-aligned within this fixed-width column, so the control
            // always starts at the same x no matter which kind it is.
            HorizontalLayout {
                width: Theme.control-column-width;
                alignment: start;

                if row.kind == 0 || row.kind == 1: HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    // Committed on `released`, not `changed`: writing on
                    // every drag pixel used to trigger a full-category
                    // reload that replaced this very model, destroying and
                    // recreating the slider mid-drag (it would visually
                    // snap back and stop tracking the pointer). `released`
                    // fires once, when the drag/interaction ends.
                    slider := Slider {
                        width: 190px;
                        minimum: row.min;
                        maximum: row.max;
                        value: row.int-value;
                        enabled: row.available && row.mode-ok;
                        released(v) => { edit-slider(row.attr, round(v)); }
                    }
                    // Bound to the slider's own live `value`, not to
                    // `row.display`, so the number keeps up with the drag
                    // without a round trip through the worker. Mirrors
                    // `Kind::display`'s own formatting for `Percent`
                    // ("80%", no space) and `IntRange` ("5 deg", one
                    // space) exactly, since nothing here goes through that
                    // function any more mid-drag.
                    Text {
                        text: row.kind == 0
                            ? "\{round(slider.value)}\{row.unit}"
                            : "\{round(slider.value)} \{row.unit}";
                        vertical-alignment: center;
                        color: Theme.text-color;
                    }
                }

                if row.kind == 2: ComboBox {
                    width: 220px;
                    model: row.choices;
                    current-index: row.int-value;
                    enabled: row.available && row.mode-ok;
                    selected(v) => { edit-choice(row.attr, self.current-index); }
                }

                if row.kind == 3: Switch {
                    checked: row.bool-value;
                    enabled: row.available && row.mode-ok;
                    toggled => { edit-switch(row.attr, self.checked); }
                }

                if row.kind == 4: LineEdit {
                    width: 220px;
                    text: row.text-value;
                    enabled: row.available && row.mode-ok;
                    accepted(t) => { edit-text(row.attr, t); }
                }

                if row.kind == 5: Button {
                    text: row.label;
                    enabled: row.available && row.mode-ok;
                    clicked => { trigger(row.attr); }
                }

                if row.kind == 6: Text {
                    text: row.display;
                    vertical-alignment: center;
                    color: Theme.text-color;
                }

                if row.kind == 7: Button {
                    text: "Edit curve (" + row.display + ")";
                    enabled: row.available && row.mode-ok;
                    clicked => { edit-curve(row.attr); }
                }

                if row.kind == 8: Button {
                    text: "Edit colors (" + row.display + ")";
                    enabled: row.available && row.mode-ok;
                    clicked => { edit-rgb(row.attr); }
                }

                if row.kind == 9: Button {
                    text: "Edit slot names";
                    enabled: row.available && row.mode-ok;
                    clicked => { edit-slot-text(row.attr); }
                }
            }

            // Column 3: a fixed-position status slot (error / unavailable /
            // wrong-mode plus the "Switch mode" button). Always
            // instantiated, even when showing nothing, so its own
            // appearance or disappearance never shifts column 2.
            HorizontalLayout {
                alignment: start;
                spacing: 8px;

                if row.error != "": Text {
                    text: row.error;
                    color: Theme.error-color;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
                if row.error == "" && !row.available: Text {
                    text: "Unavailable on this wheel";
                    color: Theme.faint-text-color;
                    vertical-alignment: center;
                }
                if row.error == "" && row.available && !row.mode-ok: Text {
                    text: "Wrong mode";
                    color: Theme.faint-text-color;
                    vertical-alignment: center;
                }
                if row.available && !row.mode-ok: Button {
                    text: "Switch mode";
                    clicked => { switch-mode(); }
                }
            }
        }

        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Palette.border;
        }
    }
}
