import { ScrollView, SpinBox, ComboBox, Switch, LineEdit, Button, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { SettingGroup, ValueSlider, Segmented, RotationDial, CurveThumb, SlotCard } from "components.slint";

// One rendered setting. `kind` is a stable numeric tag the Rust side and this
// file agree on (see `bridge::KIND_*` in `src/bridge.rs`):
//   0 = percent   (ValueSlider, 0-100, "%" suffix)
//   1 = int range (ValueSlider, `min`..`max`, `unit` suffix)
//   2 = enum      (Segmented over `choices`, `int-value` is the index)
//   3 = toggle    (Switch, `bool-value`)
//   4 = text      (LineEdit, `text-value`)
//   5 = action    (Button, no value, fires `trigger`)
//   6 = readonly  (plain Text showing `display`)
//   7 = curve     (CurveThumb from `plot` + an Edit button that opens the
//                  curve editor overlay, fires `edit-curve`)
//   8 = rgb strip (Button that opens the RGB strip editor overlay, fires
//                  `edit-rgb`)
//   9 = slot text (Button that opens the slot-text editor overlay, fires
//                  `edit-slot-text`)
//   10 = pair (two SpinBoxes, lower/upper, e.g. a deadzone)
//   11 = profile (a grid of onboard slot cards; committing the chosen index
//                 + 1, the profile number, via edit-slider)
//   12 = LIGHTSYNC effect (ComboBox over the selector labels; commits the
//                 chosen index via edit-light-effect)
//   13 = LIGHTSYNC edit-slot button (opens the slot editor overlay via
//                 edit-rgb; enabled only while `bool-value` says a CUSTOM
//                 effect is active)
//   14 = per-axis shaping toggle (a Sensitivity/Curve Segmented; commits via
//                 edit-switch, intercepted as view state on the Rust side)
export struct SettingRow {
    attr: string,
    label: string,
    help: string,
    kind: int,
    int-value: int,
    int-value2: int,
    bool-value: bool,
    text-value: string,
    display: string,
    choices: [string],
    min: int,
    max: int,
    step: int,
    unit: string,
    available: bool,
    mode-ok: bool,
    error: string,
    // The uppercase title of the card this row belongs to (see
    // `bridge::attr_group`). Consecutive rows sharing a group render inside
    // one `SettingGroup`; the page's ordered distinct groups arrive
    // separately as `SettingsList.groups`.
    group: string,
    // For a curve row (kind 7): the current curve as an SVG path-commands
    // string in the editor's 0..1 screen-fraction space, drawn by the row's
    // `CurveThumb`. Empty for every other kind.
    plot: string,
    // Bumped by the Rust side on every in-place push of this row
    // (`update_row`, `load_rows`' same-length path). The std widgets kept
    // here (Switch/ComboBox/LineEdit/SpinBox) sever their own
    // `checked:`/`current-index:`/`text:`/`value:` binding the first time
    // the widget assigns that property internally (any user interaction),
    // after which pushed model updates stop reaching it; each such control
    // watches this counter with a `changed` callback and re-asserts its
    // display property from the row. A plain `changed row.int-value` would
    // miss the case where an edit is rejected and the fresh read equals the
    // old value (the exact revert-on-error case), so the counter changes on
    // every push unconditionally. The custom ValueSlider/Segmented do not
    // need it (they never self-assign their bound property) but accept it
    // for parity.
    revision: int,
}

// The grouped settings page: the flat `rows` model (index-stable, mutated in
// place by the Rust side) rendered as titled cards. `groups` is the page's
// ordered distinct group titles; each `SettingGroup` pulls the rows whose
// `group` matches. The flat model is never restructured, so the in-place
// `set_row_data` updates and their revision re-sync keep working exactly as
// before; grouping is presentation only.
export component SettingsList inherits ScrollView {
    in property <[SettingRow]> rows;
    in property <[string]> groups;

    callback edit-slider(string, int);
    callback edit-choice(string, int);
    callback edit-switch(string, bool);
    callback edit-text(string, string);
    callback trigger(string);
    callback edit-curve(string);
    callback edit-rgb(string);
    callback edit-slot-text(string);
    callback edit-light-effect(int);
    callback edit-pair(string, bool, int);
    callback switch-mode();

    VerticalLayout {
        width: root.visible-width;
        padding: 2px;
        spacing: 14px;
        // Pack cards at their natural height from the top; without this a
        // page shorter than the viewport stretches each card to fill,
        // opening gaps inside them.
        alignment: start;

        for group in root.groups: SettingGroup {
            title: group;

            // Slint has no filtered `for`, so every row is instantiated in
            // every card and collapsed to zero height (and clipped) unless
            // its group matches this card. Row counts are small, so the
            // wasted hidden delegates are negligible.
            for row in root.rows: Rectangle {
                property <bool> mine: row.group == group;
                height: mine ? max(60px, row-layout.min-height) : 0px;
                clip: true;

                // Row divider (mockup's per-row top border). Harmless on the
                // first row of a card: it reads as the header underline.
                Rectangle {
                    y: 0;
                    width: parent.width;
                    height: parent.mine ? 1px : 0px;
                    background: Theme.row-divider;
                }

                row-layout := HorizontalLayout {
                    padding: 13px;
                    spacing: 16px;

                    // Label + one-line help (stretches; the only column that
                    // may grow the row via wrapped help text).
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;

                        Text {
                            text: row.label;
                            font-weight: 600;
                            font-size: 13.5px;
                            color: Theme.text-color;
                            wrap: word-wrap;
                        }
                        Text {
                            text: row.help;
                            font-size: 12px;
                            color: Theme.muted-text-color;
                            wrap: word-wrap;
                        }
                    }

                    // Control column. Each `if` is a mutually exclusive
                    // branch on `kind`; center-aligned so a tall row keeps
                    // its control at natural height.
                    VerticalLayout {
                        alignment: center;

                        // Sliders. `wheel_range` gets the rotation dial + a
                        // large readout beside the slider; every other slider
                        // is a plain ValueSlider.
                        if (row.kind == 0 || row.kind == 1) && row.attr == "wheel_range": HorizontalLayout {
                            spacing: 16px;
                            alignment: end;

                            RotationDial {
                                value: row.int-value;
                                minimum: row.min;
                                maximum: row.max;
                            }
                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                HorizontalLayout {
                                    alignment: start;
                                    spacing: 4px;
                                    Text {
                                        text: row.int-value;
                                        font-size: 28px;
                                        font-weight: 700;
                                        color: Theme.text-color;
                                    }
                                    Text {
                                        text: row.unit;
                                        font-size: 14px;
                                        color: Theme.muted-text-color;
                                        vertical-alignment: bottom;
                                        y: parent.height - self.height - 5px;
                                    }
                                }
                                ValueSlider {
                                    width: 220px;
                                    minimum: row.min;
                                    maximum: row.max;
                                    value: row.int-value;
                                    step: row.step;
                                    unit: row.unit;
                                    percent: false;
                                    show-value: false;
                                    enabled: row.available && row.mode-ok;
                                    revision: row.revision;
                                    released(v) => { edit-slider(row.attr, v); }
                                }
                            }
                        }

                        if (row.kind == 0 || row.kind == 1) && row.attr != "wheel_range": ValueSlider {
                            width: 260px;
                            minimum: row.min;
                            maximum: row.max;
                            value: row.int-value;
                            step: row.step;
                            unit: row.unit;
                            percent: row.kind == 0;
                            enabled: row.available && row.mode-ok;
                            revision: row.revision;
                            released(v) => { edit-slider(row.attr, v); }
                        }

                        // Short enums as a segmented pill group.
                        if row.kind == 2: Segmented {
                            options: row.choices;
                            current: row.int-value;
                            enabled: row.available && row.mode-ok;
                            revision: row.revision;
                            selected(i) => { edit-choice(row.attr, i); }
                        }

                        // Per-axis shaping: a Sensitivity/Curve segmented; the
                        // Rust side reads its attr as pure view state.
                        if row.kind == 14: Segmented {
                            options: ["Sensitivity", "Curve"];
                            current: row.bool-value ? 1 : 0;
                            enabled: row.available && row.mode-ok;
                            revision: row.revision;
                            selected(i) => { edit-switch(row.attr, i == 1); }
                        }

                        if row.kind == 3: Switch {
                            checked: row.bool-value;
                            enabled: row.available && row.mode-ok;
                            property <int> rev: row.revision;
                            changed rev => { self.checked = row.bool-value; }
                            toggled => { edit-switch(row.attr, self.checked); }
                        }

                        if row.kind == 4: LineEdit {
                            width: 200px;
                            text: row.text-value;
                            enabled: row.available && row.mode-ok;
                            property <int> rev: row.revision;
                            changed rev => { self.text = row.text-value; }
                            accepted(t) => { edit-text(row.attr, t); }
                        }

                        if row.kind == 5: Button {
                            text: row.label;
                            enabled: row.available && row.mode-ok;
                            clicked => { trigger(row.attr); }
                        }

                        if row.kind == 6: Text {
                            text: row.display;
                            vertical-alignment: center;
                            color: Theme.text-color;
                            wrap: word-wrap;
                        }

                        // Curve: a live thumbnail + Edit.
                        if row.kind == 7: HorizontalLayout {
                            spacing: 12px;
                            alignment: end;
                            CurveThumb { commands: row.plot; }
                            VerticalLayout {
                                alignment: center;
                                Button {
                                    text: "Edit";
                                    enabled: row.available && row.mode-ok;
                                    clicked => { edit-curve(row.attr); }
                                }
                            }
                        }

                        if row.kind == 8: Button {
                            text: "Edit colors (" + row.display + ")";
                            enabled: row.available && row.mode-ok;
                            clicked => { edit-rgb(row.attr); }
                        }

                        if row.kind == 9: Button {
                            text: "Rename...";
                            enabled: row.available && row.mode-ok;
                            clicked => { edit-slot-text(row.attr); }
                        }

                        if row.kind == 12: ComboBox {
                            width: 220px;
                            model: row.choices;
                            current-index: row.int-value;
                            enabled: row.available && row.mode-ok;
                            property <int> rev: row.revision;
                            changed rev => { self.current-index = row.int-value; }
                            selected(v) => { edit-light-effect(self.current-index); }
                        }

                        if row.kind == 13: Button {
                            text: "Edit slot...";
                            enabled: row.available && row.mode-ok && row.bool-value;
                            clicked => { edit-rgb(row.attr); }
                        }

                        // Onboard profile slots: a 5-card grid; the active
                        // slot is highlighted, tapping one commits index + 1.
                        if row.kind == 11: VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                for name[i] in row.choices: SlotCard {
                                    width: 100px;
                                    // The choice label already reads "N:
                                    // name", so the number line is left off.
                                    number: "";
                                    name: name;
                                    active: i == row.int-value;
                                    enabled: row.available && row.mode-ok;
                                    clicked => { edit-slider(row.attr, i + 1); }
                                }
                            }
                        }

                        // Deadzone pair: lower + upper spin boxes.
                        if row.kind == 10: HorizontalLayout {
                            spacing: 12px;

                            VerticalLayout {
                                spacing: 2px;
                                Text {
                                    text: "Lower";
                                    font-size: 11px;
                                    color: Theme.muted-text-color;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    SpinBox {
                                        width: 90px;
                                        minimum: 0;
                                        maximum: row.max;
                                        value: row.int-value;
                                        enabled: row.available && row.mode-ok;
                                        property <int> rev: row.revision;
                                        changed rev => { self.value = row.int-value; }
                                        edited(v) => { edit-pair(row.attr, true, v); }
                                    }
                                    Text {
                                        text: "%";
                                        vertical-alignment: center;
                                        color: Theme.muted-text-color;
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 2px;
                                Text {
                                    text: "Upper";
                                    font-size: 11px;
                                    color: Theme.muted-text-color;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    SpinBox {
                                        width: 90px;
                                        minimum: 0;
                                        maximum: row.max;
                                        value: row.int-value2;
                                        enabled: row.available && row.mode-ok;
                                        property <int> rev: row.revision;
                                        changed rev => { self.value = row.int-value2; }
                                        edited(v) => { edit-pair(row.attr, false, v); }
                                    }
                                    Text {
                                        text: "%";
                                        vertical-alignment: center;
                                        color: Theme.muted-text-color;
                                    }
                                }
                            }
                        }
                    }

                    // Status slot: error / unavailable / wrong-mode plus the
                    // "Switch mode" affordance.
                    VerticalLayout {
                        alignment: center;

                        HorizontalLayout {
                            alignment: end;
                            spacing: 8px;

                            if row.error != "": Text {
                                text: row.error;
                                color: Theme.error-color;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }
                            if row.error == "" && !row.available: Text {
                                text: "Unavailable";
                                color: Theme.faint-text-color;
                                vertical-alignment: center;
                            }
                            if row.error == "" && row.available && !row.mode-ok: Text {
                                text: "Wrong mode";
                                color: Theme.faint-text-color;
                                vertical-alignment: center;
                            }
                            if row.available && !row.mode-ok: Button {
                                text: "Switch mode";
                                clicked => { switch-mode(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
