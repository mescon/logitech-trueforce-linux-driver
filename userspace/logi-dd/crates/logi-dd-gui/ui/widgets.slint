import { ListView, Slider, ComboBox, Switch, LineEdit, Button } from "std-widgets.slint";

// One rendered setting. `kind` is a stable numeric tag the Rust side and this
// file agree on (see `bridge::KIND_*` in `src/bridge.rs`):
//   0 = percent   (Slider, 0-100, "%" suffix)
//   1 = int range (Slider, `min`..`max`, `unit` suffix)
//   2 = enum      (ComboBox over `choices`, `int-value` is the index)
//   3 = toggle    (Switch, `bool-value`)
//   4 = text      (LineEdit, `text-value`)
//   5 = action    (Button, no value, fires `trigger`)
//   6 = readonly  (plain Text showing `display`; also used for kinds that do
//                  not have a dedicated live editor yet: deadzone pair,
//                  slot text)
//   7 = curve     (Button that opens the curve editor overlay, fires
//                  `edit-curve`)
//   8 = rgb strip (Button that opens the RGB strip editor overlay, fires
//                  `edit-rgb`)
export struct SettingRow {
    attr: string,
    label: string,
    help: string,
    kind: int,
    int-value: int,
    bool-value: bool,
    text-value: string,
    display: string,
    choices: [string],
    min: int,
    max: int,
    step: int,
    unit: string,
    available: bool,
    mode-ok: bool,
    error: string,
}

export component SettingsList inherits ListView {
    in property <[SettingRow]> rows;

    callback edit-slider(string, int);
    callback edit-choice(string, int);
    callback edit-switch(string, bool);
    callback edit-text(string, string);
    callback trigger(string);
    // Fired by a curve row's "Edit curve" button (kind 7); the app opens the
    // curve editor overlay for `attr`, seeded from that row's current value.
    callback edit-curve(string);
    // Fired by an RGB strip row's "Edit colors" button (kind 8); the app
    // opens the RGB strip editor overlay for `attr`, seeded from that row's
    // current value.
    callback edit-rgb(string);
    // Fired by the per-row "Switch mode" button, shown on a row whose
    // `mode-ok` is false. It does not say which mode: with exactly two
    // modes, whichever one the wheel is not currently in is the one this
    // row needs, so this just asks the app to flip it (same action as the
    // header's mode toggle).
    callback switch-mode();

    for row in rows: Rectangle {
        height: 72px;

        VerticalLayout {
            padding: 10px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: row.label;
                    font-weight: 600;
                }
                if !row.available: Text {
                    text: "(unavailable on this wheel)";
                    opacity: 0.6;
                }
                if row.available && !row.mode-ok: Text {
                    text: "(wrong mode)";
                    opacity: 0.6;
                }
                if row.error != "": Text {
                    text: row.error;
                    color: red;
                }
            }

            Text {
                text: row.help;
                font-size: 11px;
                opacity: 0.7;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: start;

                if row.kind == 0 || row.kind == 1: Slider {
                    width: 260px;
                    minimum: row.min;
                    maximum: row.max;
                    value: row.int-value;
                    enabled: row.available && row.mode-ok;
                    changed(v) => { edit-slider(row.attr, round(v)); }
                }
                if row.kind == 0 || row.kind == 1: Text {
                    text: row.display;
                    vertical-alignment: center;
                }

                if row.kind == 2: ComboBox {
                    width: 200px;
                    model: row.choices;
                    current-index: row.int-value;
                    enabled: row.available && row.mode-ok;
                    selected(v) => { edit-choice(row.attr, self.current-index); }
                }

                if row.kind == 3: Switch {
                    checked: row.bool-value;
                    enabled: row.available && row.mode-ok;
                    toggled => { edit-switch(row.attr, self.checked); }
                }

                if row.kind == 4: LineEdit {
                    width: 200px;
                    text: row.text-value;
                    enabled: row.available && row.mode-ok;
                    accepted(t) => { edit-text(row.attr, t); }
                }

                if row.kind == 5: Button {
                    text: row.label;
                    enabled: row.available && row.mode-ok;
                    clicked => { trigger(row.attr); }
                }

                if row.kind == 6: Text {
                    text: row.display;
                    vertical-alignment: center;
                }

                if row.kind == 7: Button {
                    text: "Edit curve (" + row.display + ")";
                    enabled: row.available && row.mode-ok;
                    clicked => { edit-curve(row.attr); }
                }

                if row.kind == 8: Button {
                    text: "Edit colors (" + row.display + ")";
                    enabled: row.available && row.mode-ok;
                    clicked => { edit-rgb(row.attr); }
                }

                if row.available && !row.mode-ok: Button {
                    text: "Switch mode";
                    clicked => { switch-mode(); }
                }
            }
        }
    }
}
