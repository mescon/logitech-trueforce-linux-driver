import { Button, Slider, LineEdit, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// One LED swatch color, as plain 0..255 channel ints so this file can build
// its background with Slint's builtin `rgb()` function without ever
// touching `logi_dd_core::Color` itself (that conversion lives in
// `bridge.rs`, the same pattern `CurvePoint` uses for the curve editor).
export struct LedColor {
    r: int,
    g: int,
    b: int,
}

// A modal overlay that edits one `Kind::RgbStrip` row: a row of clickable
// swatches (one per LED) and a picker (r/g/b sliders, a hex field, a live
// preview swatch, an "apply to all" button) for whichever swatch is
// selected. The Rust side owns the in-flight `Vec<Color>`; every edit fires
// a callback, Rust applies it and pushes the updated swatches (plus the
// selected swatch's hex text) back so both the row and the picker redraw
// from the same state the eventual `commit` writes. Cancel discards it.
// Either closes the overlay from the Rust side (`rgb-editor-open` in
// app.slint).
export component RgbStrip inherits Rectangle {
    in property <string> strip-label: "LED colors";
    in property <[LedColor]> leds: [];
    in property <string> selected-hex: "";

    // Which swatch the picker below is showing; -1 = none selected yet.
    // Purely a display concern (which slider values/preview to draw), so it
    // stays local rather than round-tripping through Rust like `leds` does.
    property <int> current-index: -1;

    // Hue/saturation/value backing the visual picker below. Local (not
    // round-tripped through Rust) for the same reason `current-index` is:
    // they only drive where the picker draws its cursors and what color it
    // emits through the existing `set-color` callback. Seeded from the
    // selected swatch's rgb whenever that swatch changes or one of the
    // other controls (sliders, hex) edits it, so every control stays in
    // sync with a single source of truth (`leds`, owned by Rust).
    property <float> hue;
    property <float> sat;
    property <float> val;

    callback select-led(int);
    callback set-color(int, int, int, int);
    callback set-hex(int, string);
    callback apply-to-all(int, int, int);
    callback commit();
    callback cancel();

    // Recompute hue/sat/val from the current hsv fields and push the
    // resulting rgb through the same `set-color` path the sliders and hex
    // field use, so Rust ownership/preview/commit keep working unchanged.
    function emit-hsv-color() {
        let c = hsv(root.hue, root.sat, root.val);
        root.set-color(root.current-index, c.red, c.green, c.blue);
    }

    // Dim the rest of the window so the overlay reads as modal. Kept a
    // fixed translucent black regardless of style/theme: see `Theme`'s own
    // doc comment for why a backdrop dimmer is not a themed "surface".
    background: Theme.scrim;

    Rectangle {
        width: 440px;
        height: 520px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.panel-background;
        border-radius: Theme.panel-radius;
        border-width: 1px;
        border-color: Theme.panel-border;

        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            Text {
                text: root.strip-label;
                font-size: 16px;
                font-weight: 700;
                color: Theme.text-color;
            }

            Text {
                text: "Click a swatch to edit its color.";
                font-size: 11px;
                color: Theme.muted-text-color;
            }

            HorizontalLayout {
                spacing: 4px;
                for led[i] in root.leds: Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 4px;
                    border-width: i == root.current-index ? 2px : 1px;
                    border-color: i == root.current-index ? Palette.accent-background : Theme.panel-border;
                    background: rgb(led.r, led.g, led.b);

                    TouchArea {
                        clicked => {
                            root.current-index = i;
                            let hsv-of = rgb(led.r, led.g, led.b).to-hsv();
                            root.hue = hsv-of.hue;
                            root.sat = hsv-of.saturation;
                            root.val = hsv-of.value;
                            root.select-led(i);
                        }
                    }
                }
            }

            if root.current-index >= 0: VerticalLayout {
                spacing: 6px;

                // Saturation/value square: the base fill is the selected hue
                // at full saturation/value, with a white->transparent
                // gradient (left = desaturated, right = saturated) and a
                // black->transparent gradient (bottom = dark, top = bright)
                // layered on top. Click or drag to set sat/val from the
                // cursor position.
                sv-square := Rectangle {
                    width: 200px;
                    height: 140px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.panel-border;
                    background: hsv(root.hue, 1, 1);

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: @linear-gradient(90deg, white 0%, transparent 100%);
                    }
                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: @linear-gradient(0deg, black 0%, transparent 100%);
                    }

                    Rectangle {
                        width: 12px;
                        height: 12px;
                        x: root.sat * sv-square.width - self.width / 2;
                        y: (1 - root.val) * sv-square.height - self.height / 2;
                        border-radius: self.width / 2;
                        border-width: 2px;
                        border-color: white;
                        background: transparent;
                    }

                    TouchArea {
                        clicked => {
                            root.sat = clamp(self.mouse-x / sv-square.width, 0, 1);
                            root.val = clamp(1 - self.mouse-y / sv-square.height, 0, 1);
                            root.emit-hsv-color();
                        }
                        moved => {
                            if (self.pressed) {
                                root.sat = clamp(self.mouse-x / sv-square.width, 0, 1);
                                root.val = clamp(1 - self.mouse-y / sv-square.height, 0, 1);
                                root.emit-hsv-color();
                            }
                        }
                    }
                }

                // Hue bar: the full hue wheel with a thin cursor indicator.
                // The square above always renders at this hue, full
                // saturation/value.
                hue-bar := Rectangle {
                    height: 16px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.panel-border;
                    background: @linear-gradient(90deg, #ff0000 0%, #ffff00 17%, #00ff00 33%, #00ffff 50%, #0000ff 67%, #ff00ff 83%, #ff0000 100%);

                    Rectangle {
                        width: 3px;
                        height: parent.height;
                        x: root.hue / 360 * hue-bar.width - self.width / 2;
                        background: white;
                        border-width: 1px;
                        border-color: Theme.panel-border;
                    }

                    TouchArea {
                        clicked => {
                            root.hue = clamp(self.mouse-x / hue-bar.width, 0, 1) * 360;
                            root.emit-hsv-color();
                        }
                        moved => {
                            if (self.pressed) {
                                root.hue = clamp(self.mouse-x / hue-bar.width, 0, 1) * 360;
                                root.emit-hsv-color();
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "R"; color: Theme.text-color; vertical-alignment: center; width: 16px; }
                    Slider {
                        width: 200px;
                        minimum: 0;
                        maximum: 255;
                        value: root.leds[root.current-index].r;
                        changed(v) => {
                            root.set-color(root.current-index, round(v), root.leds[root.current-index].g, root.leds[root.current-index].b);
                            let hsv-of = rgb(round(v), root.leds[root.current-index].g, root.leds[root.current-index].b).to-hsv();
                            root.hue = hsv-of.hue;
                            root.sat = hsv-of.saturation;
                            root.val = hsv-of.value;
                        }
                    }
                    Text { text: root.leds[root.current-index].r; color: Theme.text-color; vertical-alignment: center; width: 32px; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "G"; color: Theme.text-color; vertical-alignment: center; width: 16px; }
                    Slider {
                        width: 200px;
                        minimum: 0;
                        maximum: 255;
                        value: root.leds[root.current-index].g;
                        changed(v) => {
                            root.set-color(root.current-index, root.leds[root.current-index].r, round(v), root.leds[root.current-index].b);
                            let hsv-of = rgb(root.leds[root.current-index].r, round(v), root.leds[root.current-index].b).to-hsv();
                            root.hue = hsv-of.hue;
                            root.sat = hsv-of.saturation;
                            root.val = hsv-of.value;
                        }
                    }
                    Text { text: root.leds[root.current-index].g; color: Theme.text-color; vertical-alignment: center; width: 32px; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "B"; color: Theme.text-color; vertical-alignment: center; width: 16px; }
                    Slider {
                        width: 200px;
                        minimum: 0;
                        maximum: 255;
                        value: root.leds[root.current-index].b;
                        changed(v) => {
                            root.set-color(root.current-index, root.leds[root.current-index].r, root.leds[root.current-index].g, round(v));
                            let hsv-of = rgb(root.leds[root.current-index].r, root.leds[root.current-index].g, round(v)).to-hsv();
                            root.hue = hsv-of.hue;
                            root.sat = hsv-of.saturation;
                            root.val = hsv-of.value;
                        }
                    }
                    Text { text: root.leds[root.current-index].b; color: Theme.text-color; vertical-alignment: center; width: 32px; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Hex"; color: Theme.text-color; vertical-alignment: center; }
                    LineEdit {
                        width: 90px;
                        text: root.selected-hex;
                        accepted(t) => {
                            root.set-hex(root.current-index, t);
                            let hsv-of = rgb(root.leds[root.current-index].r, root.leds[root.current-index].g, root.leds[root.current-index].b).to-hsv();
                            root.hue = hsv-of.hue;
                            root.sat = hsv-of.saturation;
                            root.val = hsv-of.value;
                        }
                    }
                    Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.panel-border;
                        background: rgb(root.leds[root.current-index].r, root.leds[root.current-index].g, root.leds[root.current-index].b);
                    }
                    Button {
                        text: "Apply to all";
                        clicked => {
                            root.apply-to-all(root.leds[root.current-index].r, root.leds[root.current-index].g, root.leds[root.current-index].b);
                        }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalLayout {
                alignment: end;
                spacing: 8px;
                Button { text: "Cancel"; clicked => { root.cancel(); } }
                Button { text: "Commit"; clicked => { root.commit(); } }
            }
        }
    }
}
